---
import { cn } from "@bejamas/ui/lib/utils";
import type { HTMLAttributes } from "astro/types";

type Props = {
  class?: string;
} & HTMLAttributes<"thead">;

const {
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<thead data-slot="table-header" class={cn("[&_tr]:border-b", className)} {...rest}>
  <slot />
</thead>

