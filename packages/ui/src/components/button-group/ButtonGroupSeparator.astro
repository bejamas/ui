---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/ui/lib/utils";
import Separator from "../separator/Separator.astro";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
  orientation?: "horizontal" | "vertical";
  decorative?: boolean;
}

const {
  class: className = "",
  orientation = "vertical",
  decorative = true,
  ...rest
} = Astro.props as Props;
---

<Separator
  {...rest}
  decorative={decorative}
  data-slot="button-group-separator"
  data-orientation={orientation}
  orientation={orientation}
  class={cn(
    "cn-button-group-separator bg-input relative self-stretch data-[orientation=horizontal]:mx-px data-[orientation=horizontal]:w-auto data-[orientation=vertical]:my-px data-[orientation=vertical]:h-auto",
    className,
  )}
/>
