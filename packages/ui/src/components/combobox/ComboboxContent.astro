---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/ui/lib/utils";
import { cva } from "class-variance-authority";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
  side?: "top" | "bottom";
  align?: "start" | "center" | "end";
  sideOffset?: number;
  alignOffset?: number;
}

const {
  class: className = "",
  side = "bottom",
  align = "center",
  sideOffset = 6,
  alignOffset = 0,
  ...rest
} = Astro.props as Props;

const contentVariants = cva(
  [
    "z-50 outline-hidden",
    "bg-popover text-popover-foreground overflow-hidden rounded-lg shadow-md ring-1 ring-foreground/10 duration-100",
    "data-open:animate-in data-closed:animate-out",
    "data-closed:fade-out-0 data-open:fade-in-0",
    "data-closed:zoom-out-95 data-open:zoom-in-95",
    "*:data-[slot=input-group]:m-1 *:data-[slot=input-group]:mb-0 *:data-[slot=input-group]:shadow-none",
    "[--tw-animation-fill-mode:both]",
  ],
  {
    variants: {
      side: {
        top: "data-[side=top]:slide-in-from-bottom-2",
        bottom: "data-[side=bottom]:slide-in-from-top-2",
      },
    },
    defaultVariants: {
      side: "bottom",
    },
  },
);
---

<div
  {...rest}
  data-slot="combobox-content"
  data-side={side}
  data-align={align}
  data-side-offset={sideOffset}
  data-align-offset={alignOffset}
  hidden
  class={cn(
    "cn-combobox-content cn-combobox-content-logical cn-menu-target group/combobox-content relative w-[var(--anchor-width)] max-h-[var(--available-height)] max-w-[var(--available-width)] min-w-[max(8rem,var(--anchor-width))] origin-(--transform-origin)",
    contentVariants({ side }),
    className,
  )}
>
  <slot />
</div>
