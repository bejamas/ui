import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/ui/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
  value?: number[];
  defaultValue?: number[];
  min?: number;
  max?: number;
  step?: number;
  orientation?: "horizontal" | "vertical";
  disabled?: boolean;
}

const {
  class: className = "",
  value,
  defaultValue,
  min = 0,
  max = 100,
  step = 1,
  orientation = "horizontal",
  disabled = false,
  ...rest
} = Astro.props as Props;

const resolvedValues =
  Array.isArray(value) && value.length > 0
    ? value
    : Array.isArray(defaultValue) && defaultValue.length > 0
      ? defaultValue
      : [min, max];
---

<div
  {...rest}
  data-slot="slider"
  data-default-value={resolvedValues.join(",")}
  data-min={min}
  data-max={max}
  data-step={step}
  data-orientation={orientation}
  data-disabled={disabled ? "true" : undefined}
  class={cn("data-horizontal:w-full data-vertical:h-full", className)}
>
  <div
    data-disabled={disabled ? "true" : undefined}
    class="data-vertical:min-h-40 relative flex w-full touch-none items-center select-none data-disabled:opacity-50 data-vertical:h-full data-vertical:w-auto data-vertical:flex-col"
  >
    <div
      data-slot="slider-track"
      class="bg-muted rounded-full data-horizontal:h-1.5 data-horizontal:w-full data-vertical:h-full data-vertical:w-1.5 relative grow overflow-hidden select-none"
    >
      <div
        data-slot="slider-range"
        class="bg-primary select-none data-horizontal:h-full data-vertical:w-full"
      >
      </div>
    </div>
    {
      resolvedValues.map((_, index) => (
        <div
          data-slot="slider-thumb"
          data-index={index}
          class="border-primary ring-ring/50 size-4 rounded-full border bg-white shadow-sm transition-[color,box-shadow] hover:ring-4 focus-visible:ring-4 focus-visible:outline-hidden block shrink-0 select-none disabled:pointer-events-none disabled:opacity-50"
        />
      ))
    }
  </div>
</div>

<script>
  import { createSlider } from "@data-slot/slider";

  document.querySelectorAll('[data-slot="slider"]').forEach((el) => {
    const element = el as HTMLElement;
    // Don't pass defaultValue in options - let library read from data-default-value
    // attribute directly. The library handles single vs range values correctly.
    createSlider(element, {
      min: Number(element.dataset.min) || 0,
      max: Number(element.dataset.max) || 100,
      step: Number(element.dataset.step) || 1,
      orientation:
        (element.dataset.orientation as "horizontal" | "vertical") ||
        "horizontal",
      disabled: element.dataset.disabled === "true",
    });
  });
</script>
