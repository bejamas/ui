---
import { cn } from "@bejamas/registry/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"td"> {
  class?: string;
}

const {
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<td
  data-slot="table-cell"
  class={cn("cn-table-cell", className)}
  {...rest}
>
  <slot />
</td>
