---
import { cn } from "@bejamas/registry/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"th"> {
  class?: string;
}

const {
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<th
  data-slot="table-head"
  class={cn("cn-table-head", className)}
  {...rest}
>
  <slot />
</th>
