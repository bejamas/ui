---
import { cn } from "@bejamas/registry/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {
  class?: string;
  /** Radix-like: render wrapper so the child can be the interactive element */
  asChild?: boolean;
}

const {
  class: className = "",
  asChild = false,
  type = "button",
  ...rest
} = Astro.props as Props;
---

{
  asChild ? (
    <div
      data-slot="hover-card-trigger"
      data-as-child
      class={cn("cn-hover-card-trigger", "inline-flex items-center", className)}
    >
      <slot />
    </div>
  ) : (
    <button
      {...rest}
      type={type}
      data-slot="hover-card-trigger"
      class={cn("cn-hover-card-trigger", "inline-flex items-center", className)}
    >
      <slot />
    </button>
  )
}
