---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/registry/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
}

const { class: className = "", ...rest } = Astro.props as Props;
---

<div
  {...rest}
  data-slot="navigation-menu-indicator"
  class={cn(
    "cn-navigation-menu-indicator absolute left-0 top-0 z-0 pointer-events-none opacity-0 data-instant:transition-opacity transition-[translate,width,height] duration-150 ease data-[state=visible]:opacity-100",
    "translate-x-(--indicator-left,0px) translate-y-(--indicator-top,0px)",
    "w-(--indicator-width,0) h-(--indicator-height,0)",
    className,
  )}
>
  <div class="cn-navigation-menu-indicator-surface absolute inset-0 rounded-[inherit]"></div>
  <div class="cn-navigation-menu-indicator-arrow absolute top-full left-1/2 h-2 w-2 -translate-x-1/2 -translate-y-[40%] rotate-45"></div>
</div>
