---
import { cn } from "@bejamas/registry/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"p"> {
  class?: string;
}

const {
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<p
  {...rest}
  data-slot="item-description"
  class={cn(
    "cn-item-description",
    "line-clamp-2 text-balance",
    className,
  )}
>
  <slot />
</p>
