---
import { cva } from "class-variance-authority";
import { cn } from "@bejamas/registry/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"details"> {
  value: string;
  open?: boolean;
  class?: string;
}

const {
  value,
  open = false,
  class: className = "",
  ...rest
} = Astro.props as Props;

const itemVariants = cva("");
---

<div
  {...rest}
  data-value={value}
  data-slot="accordion-item"
  class={cn("cn-accordion-item", itemVariants(), "group/accordion", className)}
>
  <slot />
</div>
