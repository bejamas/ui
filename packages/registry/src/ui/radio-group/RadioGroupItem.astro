---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/registry/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  value: string;
  class?: string;
  name?: string;
  checked?: boolean;
  disabled?: boolean;
  required?: boolean;
  id?: string;
  "aria-invalid"?: boolean;
}

const {
  class: className = "",
  id: inputId,
  name,
  value,
  checked = false,
  disabled = false,
  required = false,
  "aria-invalid": ariaInvalid,
  ...rest
} = Astro.props as Props;
---

<div
  {...rest}
  data-slot="radio-group-item"
  data-checked={checked ? "true" : undefined}
  class={cn(
    "cn-radio-group-item group/radio-group-item peer relative aspect-square shrink-0 border outline-none after:absolute after:-inset-x-3 after:-inset-y-2 peer-focus-visible:border-ring peer-focus-visible:ring-ring/50 peer-focus-visible:ring-3 peer-disabled:cursor-not-allowed peer-disabled:opacity-50",
    className,
  )}
>
  <input
    type="radio"
    id={inputId}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    required={required}
    aria-invalid={ariaInvalid}
    class="peer absolute inset-0 m-0 opacity-0"
  />
  <span
    aria-hidden="true"
    data-slot="radio-group-indicator"
    class="cn-radio-group-indicator"
  >
    <span class="cn-radio-group-indicator-icon"></span>
  </span>
</div>

<script is:inline type="module">
  if (!window.__bejamasRadioGroupSync) {
    window.__bejamasRadioGroupSync = true;

    const syncRadio = (input) => {
      const root = input?.closest?.('[data-slot="radio-group-item"]');
      if (!root) return;

      if (input.checked) {
        root.dataset.checked = "true";
      } else {
        delete root.dataset.checked;
      }

      if (input.disabled) {
        root.dataset.disabled = "true";
      } else {
        delete root.dataset.disabled;
      }
    };

    const syncAllRadios = () => {
      document
        .querySelectorAll(
          '[data-slot="radio-group-item"] > input[type="radio"]',
        )
        .forEach((input) => syncRadio(input));
    };

    syncAllRadios();

    document.addEventListener("change", (event) => {
      const input = event.target?.closest?.(
        '[data-slot="radio-group-item"] > input[type="radio"]',
      );
      if (!input) return;

      const name = input.getAttribute("name");
      if (!name) {
        syncRadio(input);
        return;
      }

      document
        .querySelectorAll(`input[type="radio"][name="${CSS.escape(name)}"]`)
        .forEach((radio) => syncRadio(radio));
    });
  }
</script>
