---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/registry/lib/utils";

interface Props extends HTMLAttributes<"div"> {
  heading?: string;
  value?: string;
  forceMount?: boolean;
  class?: string;
}

const {
  heading,
  value,
  forceMount = false,
  class: className = "",
  ...rest
} = Astro.props as Props;
---

<div
  {...rest}
  role="group"
  data-slot="command-group"
  data-value={value}
  data-force-mount={forceMount ? "true" : undefined}
  class={cn("cn-command-group", className)}
>
  {
    heading && (
      <div data-slot="command-group-heading" cmdk-group-heading>
        {heading}
      </div>
    )
  }
  <slot />
</div>
