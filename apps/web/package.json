{
  "name": "@bejamas/web",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "start": "astro dev",
    "build": "bun run build:compiled-styles && bun run build:style-registry && bun run build:registry && bun run normalize-component-paths-in-registry && bun run build:docs && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "watch:style-artifacts": "bun run scripts/watch-style-artifacts.ts",
    "build:compiled-styles": "bun run ../../packages/create-config/scripts/generate-compiled-style-css.ts",
    "build:style-registry": "bun run ../../packages/registry/scripts/build-web-style-registry.ts",
    "generate:ui-package": "bun run ../../packages/ui/scripts/generate-from-style-registry.ts",
    "build:registry": "bun x shadcn build",
    "build:docs": "bun x bejamas@canary docs:build",
    "normalize-component-paths-in-registry": "bun run scripts/normalize-paths.ts",
    "check-types": "astro check"
  },
  "dependencies": {
