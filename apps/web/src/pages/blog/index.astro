---
import { getCollection } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Date } from "@bejamas/ui/components/date";

import { sortBlogEntries, getBlogHref } from "@/utils/blog";

const posts = sortBlogEntries(await getCollection("blog"));
---

<StarlightPage
  hasSidebar={false}
  frontmatter={{
    title: "Blog",
    description:
      "Notes on building Astro-first UI, content workflows, and the primitives behind bejamas/ui.",
    template: "splash",
  }}
>
  <div data-page-scope="blog-index" hidden></div>
  <div class="not-content mb-8">
    <h1 class="text-3xl font-medium tracking-tight">Blog</h1>
    <p class="mt-3 text-muted-foreground text-balance">
      Notes on building Astro-first UI, content workflows, and the primitives
      behind bejamas/ui.
    </p>
  </div>
  <div class="not-content">
    {
      posts.map((post) => (
        <a href={getBlogHref(post.id)} class="blog-list-item group block py-6">
          <p class="text-sm text-muted-foreground">
            <Date date={post.data.publishDate} format="long" />
          </p>
          <h2 class="mt-1 text-lg font-medium tracking-tight text-foreground group-hover:underline underline-offset-4">
            {post.data.title}
          </h2>
          {(post.data.excerpt ?? post.data.description) && (
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              {post.data.excerpt ?? post.data.description}
            </p>
          )}
        </a>
      ))
    }
  </div>
</StarlightPage>

<style is:global>
  :root:has([data-page-scope="blog-index"]) .sl-container {
    max-width: 42rem;
  }

  :root:has([data-page-scope="blog-index"]) .content-panel:first-of-type {
    display: none;
  }

  :root:has([data-page-scope="blog-index"]) .content-panel {
    padding: 0;
    padding-top: calc(var(--spacing) * 16);
  }

  :root:has([data-page-scope="blog-index"]) .main-frame-splash {
    --sl-splash-frame-top: calc(var(--spacing) * 18);
    --sl-splash-frame-inline: calc(var(--spacing) * 6);
  }

  .blog-list-item + .blog-list-item {
    border-top: 1px solid var(--border);
  }
</style>
