---
import { getCollection, getEntry, render } from "astro:content";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Date } from "@bejamas/ui/components/date";

import BlogByline from "@/components/blog/BlogByline.astro";
import BlogDraftBadge from "@/components/blog/BlogDraftBadge.astro";
import * as blogComponents from "@/components/blog/mdx-components";
import {
  filterVisibleBlogEntries,
  shouldIncludeDraftBlogEntries,
} from "@/utils/blog";

export const prerender = true;

export async function getStaticPaths() {
  const showDrafts = shouldIncludeDraftBlogEntries({
    isDev: import.meta.env.DEV,
  });
  const posts = filterVisibleBlogEntries(await getCollection("blog"), {
    includeDrafts: showDrafts,
  });

  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const slug = Astro.params.slug;

if (!slug) {
  throw new Error("Missing blog slug.");
}

const entry = await getEntry("blog", slug);

if (!entry) {
  throw new Error(`Blog entry not found for slug: ${slug}`);
}

const { Content } = await render(entry);
---

<StarlightPage
  hasSidebar={false}
  frontmatter={{
    title: entry.data.title,
    description: entry.data.description,
    tableOfContents: false,
    lastUpdated: entry.data.updatedDate ?? entry.data.publishDate,
    template: "splash",
  }}
>
  <div data-page-scope="blog-post" hidden></div>
  <a
    href="/blog"
    class="not-content inline-block mb-12 no-underline text-sm text-muted-foreground hover:text-foreground"
    >← Blog</a
  >
  <div class="not-content">
    <div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
      <p>
        Published <Date date={entry.data.publishDate} format="long" />
      </p>
      {entry.data.draft && <BlogDraftBadge />}
    </div>
    <h1
      class="text-3xl min-[50rem]:text-4xl leading-tight font-medium text-foreground text-balance mt-4 tracking-tight"
    >
      {entry.data.title}
    </h1>
    {
      entry.data.description && (
        <p class="text-balance mt-4 max-w-[52ch] text-muted-foreground">
          {entry.data.description}
        </p>
      )
    }
    <BlogByline authors={entry.data.authors} />
  </div>
  <Content components={blogComponents} />
</StarlightPage>

<style is:global>
  :root:has([data-page-scope="blog-post"]) .sl-container {
    max-width: 42rem;
  }

  :root:has([data-page-scope="blog-post"]) .content-panel:first-of-type {
    display: none;
  }

  :root:has([data-page-scope="blog-post"]) .content-panel {
    padding: 0;
    padding-top: calc(var(--spacing) * 16);
  }

  :root:has([data-page-scope="blog-post"]) .main-frame-splash {
    --sl-splash-frame-top: calc(var(--spacing) * 18);
    --sl-splash-frame-inline: calc(var(--spacing) * 6);
  }

  :root:has([data-page-scope="blog-post"]) .sl-markdown-content {
    --sl-content-gap-y: 1.25rem;
  }

  :root:has([data-page-scope="blog-post"])
    .sl-markdown-content
    h2:not(:where(.not-content *)) {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  :root:has([data-page-scope="blog-post"])
    .sl-markdown-content
    h3:not(:where(.not-content *)) {
    margin-top: 2rem;
  }
</style>
