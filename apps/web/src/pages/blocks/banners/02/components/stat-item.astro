---
interface Props {
  value: string;
  description: string;
}

const { value, description } = Astro.props;
---

<div class="flex flex-col gap-2">
  <span class="text-2xl md:text-3xl font-semibold tracking-tight text-foreground">{value}</span>
  <p class="text-sm text-muted-foreground">{description}</p>
</div>
