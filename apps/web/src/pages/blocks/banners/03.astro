---
import BlockExampleLayout from "@/components/BlockExampleLayout.astro";
---

<BlockExampleLayout>
  <section class="relative min-h-svh w-full overflow-hidden text-foreground @container">
    <img
      src="https://gradient.bejamas.com/api/gradient.png?color=7c5cff&funkiness=15&contrast=0&noise=0&w=800&h=600&seed=9zqtablo&shape=ellipse"
      class="absolute inset-0 w-full h-full object-cover"
      alt=""
    />
    <div class="relative flex flex-col justify-between gap-12 min-h-svh max-w-480 mx-auto px-4 md:px-8 py-10">
      <div class="flex flex-col-reverse md:flex-row md:justify-between md:items-start gap-6">
        <h2 class="text-[clamp(2.5rem,6vw,4rem)] font-semibold leading-[1.1] tracking-tight max-w-136">
          Our reputation </br>speaks
        </h2>
        <p class="text-lg font-medium tracking-tight md:pt-3">Banners</p>
      </div>
      <div class="flex flex-col-reverse md:flex-row md:justify-between md:items-end gap-6">
        <p class="text-lg md:text-xl font-medium leading-normal tracking-tight max-w-90">
          We believe happy customers are the heartbeat of every great business — that's why we let their experiences tell our story.
        </p>
        <div class="text-[clamp(2.5rem,6vw,4rem)] font-semibold leading-[1.1] tracking-tight md:text-right">
          <p>through</p>
          <p>our customers</p>
        </div>
      </div>
    </div>
  </section>
</BlockExampleLayout>
