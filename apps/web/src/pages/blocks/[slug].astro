---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { getCollection, getEntry, render } from "astro:content";
import BlockPreview from "@/components/BlockPreview.astro";
import BlocksNav from "@/components/BlocksNav.astro";

export const prerender = true;

const block = await getEntry("blocks", Astro.params.slug);
const blockItems = block?.data.items ?? [];

export async function getStaticPaths() {
  const blocks = await getCollection("blocks");

  return blocks.map((block) => ({
    params: { slug: block.id },
  }));
}
---

<script src="//unpkg.com/alpinejs" defer></script>

<StarlightPage
  hasSidebar={true}
  frontmatter={{
    title: "Building blocks for content-driven sites.",
    template: "splash",
  }}
>
  <div data-page-scope="blocks-slug" hidden></div>
  <BlocksNav />

  {
    <section class="text-left not-content space-y-20">
      {blockItems.map((item) => (
        <BlockPreview item={item} />
      ))}
    </section>
  }
</StarlightPage>

<style is:global>
  @reference "tailwindcss";

  :root:has([data-page-scope="blocks-slug"]) .content-panel {
    @apply text-center border-0 pt-30 pb-0 first:pt-10;
  }

  :root:has([data-page-scope="blocks-slug"]) .content-panel + .content-panel {
    @apply pt-10;
  }

  :root:has([data-page-scope="blocks-slug"]) .content-panel h1 {
    @apply text-5xl font-medium text-left max-w-2xl text-balance mx-0;
  }

  :root:has([data-page-scope="blocks-slug"]) .sl-container {
    @apply max-w-[1500px] mx-auto;
  }
</style>
