---
import { Button } from "@bejamas/ui/components/button";

interface Props {
  name: string;
  price_main: string;
  price_cents: string;
  description: string;
}

const { name, price_main, price_cents, description } = Astro.props;
---

<div class="flex flex-col border border-border overflow-hidden p-4 pt-6">
  <div class="flex flex-col gap-4">
    <span class="text-2xl font-semibold tracking-tight text-foreground">
      {name}
    </span>
    <p class="text-base leading-relaxed text-muted-foreground">
      {description}
    </p>
  </div>
  <div class="border-t border-border mt-10 pt-4">
    <div class="flex items-start">
      <span class="text-[clamp(6rem,12vw,10rem)] font-medium leading-none tracking-tighter text-foreground">
        {price_main}
      </span>
      <span class="text-9 font-medium leading-none tracking-tight text-foreground mt-4">
        {price_cents}
      </span>
    </div>
    <div class="flex justify-end mt-4">
      <Button size="sm">
        Choose {name}
      </Button>
    </div>
  </div>
</div>
