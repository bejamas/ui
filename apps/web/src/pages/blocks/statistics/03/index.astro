---
import BlockExampleLayout from "@/components/BlockExampleLayout.astro";
import StatItem from "./components/stat-item.astro";
---

<BlockExampleLayout>
  <div class="max-w-400 py-20 md:py-40 mx-auto px-8 @container text-foreground">
    <div class="flex flex-col lg:flex-row lg:justify-between gap-10 lg:gap-[10%]">
      <div class="w-full lg:max-w-120 flex flex-col justify-between gap-10">
        <div class="flex flex-col sm:flex-row gap-4">
          <img class="rounded-sm w-full object-cover aspect-ratio-square h-76" src="https://pbs.twimg.com/media/G0x-gj6bAAAJkHH?format=jpg&name=large">
          <img class="rounded-sm w-full object-cover aspect-ratio-square h-76" src="https://pbs.twimg.com/media/G0x-gkSbcAAaH3Z?format=jpg&name=large">
        </div>
        <h2 class="font-medium text-[3rem] lg:text-[4rem] tracking-tight leading-[1.1] text-balance">Our capabilites in numbers</h2>
      </div>
      <div class="w-full lg:max-w-190 flex flex-col justify-end gap-9">
        <StatItem value="$3" suffix="B+" description="Approximate earning in year 2025"/>
        <StatItem value="14" suffix="" description="Locking duration in days quickly"/>
        <StatItem value="98" suffix="%" description="A proven record of customer satisfaction"/>
        <StatItem value="27" suffix="" description="Grew our network with exciting new collaborators"/>
      </div>
    </div>
  </div>
</BlockExampleLayout>
