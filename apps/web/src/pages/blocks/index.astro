---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import { getCollection } from "astro:content";
import BlockPreview from "@/components/BlockPreview.astro";
import BlocksNav from "@/components/BlocksNav.astro";

const blocks = await getCollection("blocks");
---

<script is:inline src="//unpkg.com/alpinejs" defer></script>

<StarlightPage
  hasSidebar={true}
  frontmatter={{
    title: "Building blocks for content-driven sites.",
    template: "splash",
  }}
>
  <div data-page-scope="blocks-index" hidden></div>
  <BlocksNav />

  {
    blocks.map((block) => (
      <section class="text-left not-content space-y-20">
        {(block.data.items ?? []).map((item) => (
          <BlockPreview item={item} />
        ))}
      </section>
    ))
  }

  <style is:global>
    @reference "tailwindcss";

    :root:has([data-page-scope="blocks-index"]) .content-panel {
      @apply text-center border-0 pt-30 pb-0 first:pt-10;
    }

    :root:has([data-page-scope="blocks-index"]) .content-panel + .content-panel {
      @apply pt-10;
    }

    :root:has([data-page-scope="blocks-index"]) .content-panel h1 {
      @apply text-5xl font-medium text-left max-w-2xl text-balance mx-0;
    }

    :root:has([data-page-scope="blocks-index"]) .sl-container {
      @apply max-w-[1500px] mx-auto;
    }
  </style>
</StarlightPage>
