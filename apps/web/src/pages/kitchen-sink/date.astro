---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Date as DateComponent } from "@bejamas/registry/ui/date";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Date</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Short Format">
        <DateComponent format="short" datetime="2025-06-13" />
      </KitchenSinkSection>

      <KitchenSinkSection title="Full Format">
        <DateComponent format="full" datetime="2025-06-13" />
      </KitchenSinkSection>

      <KitchenSinkSection title="Long Format (Default)">
        <DateComponent datetime="2025-06-13" />
      </KitchenSinkSection>

      <KitchenSinkSection title="With Time">
        <DateComponent format="long" includeTime datetime="2025-06-13T14:30:00" />
      </KitchenSinkSection>

      <KitchenSinkSection title="Time Only">
        <DateComponent format="time" datetime="2025-06-13T14:30:00" />
      </KitchenSinkSection>

      <KitchenSinkSection title="Custom Locale">
        <div class="space-y-2">
          <div class="flex items-center gap-3">
            <span class="text-sm text-muted-foreground w-10">fr-FR</span>
            <DateComponent datetime="2025-06-13" locale="fr-FR" />
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-muted-foreground w-10">de-DE</span>
            <DateComponent datetime="2025-06-13" locale="de-DE" />
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-muted-foreground w-10">ja-JP</span>
            <DateComponent datetime="2025-06-13" locale="ja-JP" />
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-muted-foreground w-10">pl-PL</span>
            <DateComponent datetime="2025-06-13" locale="pl-PL" />
          </div>
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
