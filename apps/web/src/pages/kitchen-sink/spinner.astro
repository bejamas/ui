---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Spinner as SpinnerComponent } from "@bejamas/registry/ui/spinner";
import { Button } from "@bejamas/registry/ui/button";
import { Badge } from "@bejamas/registry/ui/badge";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Spinner</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <SpinnerComponent />
      </KitchenSinkSection>

      <KitchenSinkSection title="Sizes">
        <div class="flex items-center gap-4">
          <SpinnerComponent class="size-3" />
          <SpinnerComponent />
          <SpinnerComponent class="size-6" />
          <SpinnerComponent class="size-8" />
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="In Button">
        <div class="flex items-center gap-3 flex-wrap">
          <Button disabled>
            <SpinnerComponent class="size-4" />
            Loading...
          </Button>
          <Button disabled variant="outline">
            <SpinnerComponent class="size-4" />
            Please wait
          </Button>
          <Button disabled variant="secondary">
            <SpinnerComponent class="size-4" />
            Processing
          </Button>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="In Badge">
        <div class="flex items-center gap-3 flex-wrap">
          <Badge>
            <SpinnerComponent class="size-3" />
            Syncing
          </Badge>
          <Badge variant="secondary">
            <SpinnerComponent class="size-3" />
            Updating
          </Badge>
          <Badge variant="outline">
            <SpinnerComponent class="size-3" />
            Processing
          </Badge>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Custom Color">
        <div class="flex items-center gap-4">
          <SpinnerComponent class="text-blue-500" />
          <SpinnerComponent class="text-green-500" />
          <SpinnerComponent class="text-destructive" />
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
