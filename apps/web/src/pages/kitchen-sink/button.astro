---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Button as ButtonComponent } from "@bejamas/registry/ui/button";
import { Spinner } from "@bejamas/registry/ui/spinner";
import {
  MailIcon,
  PlusIcon,
  ChevronRightIcon,
  DownloadIcon,
  TrashIcon,
  SettingsIcon,
  SearchIcon,
  HeartIcon,
} from "@lucide/astro";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Button</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Variants">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent>Default</ButtonComponent>
          <ButtonComponent variant="secondary">Secondary</ButtonComponent>
          <ButtonComponent variant="outline">Outline</ButtonComponent>
          <ButtonComponent variant="ghost">Ghost</ButtonComponent>
          <ButtonComponent variant="destructive">Destructive</ButtonComponent>
          <ButtonComponent variant="link">Link</ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Sizes">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent size="sm">Small</ButtonComponent>
          <ButtonComponent size="default">Default</ButtonComponent>
          <ButtonComponent size="lg">Large</ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Icons">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent>
            <MailIcon />
            Login with Email
          </ButtonComponent>
          <ButtonComponent variant="secondary">
            <PlusIcon />
            Create New
          </ButtonComponent>
          <ButtonComponent variant="outline">
            Next
            <ChevronRightIcon />
          </ButtonComponent>
          <ButtonComponent variant="ghost">
            <DownloadIcon />
            Download
          </ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Icon Only">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent size="icon-sm" variant="outline" aria-label="Search">
            <SearchIcon />
          </ButtonComponent>
          <ButtonComponent size="icon" variant="outline" aria-label="Settings">
            <SettingsIcon />
          </ButtonComponent>
          <ButtonComponent size="icon-lg" variant="outline" aria-label="Favorite">
            <HeartIcon />
          </ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="As Link">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent as="a" href="#button-link">Default Link</ButtonComponent>
          <ButtonComponent as="a" href="#button-link" variant="outline"
            >Outline Link</ButtonComponent
          >
          <ButtonComponent as="a" href="#button-link" variant="ghost">Ghost Link</ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Disabled">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent disabled>Default</ButtonComponent>
          <ButtonComponent disabled variant="secondary">Secondary</ButtonComponent>
          <ButtonComponent disabled variant="outline">Outline</ButtonComponent>
          <ButtonComponent disabled variant="destructive">Destructive</ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Loading">
        <div class="flex items-center gap-2 flex-wrap">
          <ButtonComponent disabled>
            <Spinner />
            Please wait
          </ButtonComponent>
          <ButtonComponent disabled variant="secondary">
            <Spinner />
            Loading...
          </ButtonComponent>
          <ButtonComponent disabled variant="outline">
            <Spinner />
            Saving
          </ButtonComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Full Width">
        <div class="flex flex-col gap-2 max-w-sm">
          <ButtonComponent class="w-full">Full Width Button</ButtonComponent>
          <ButtonComponent class="w-full" variant="outline">Full Width Outline</ButtonComponent>
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
