---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import {
  LinkGroup as LinkGroupComponent,
  LinkGroupTitle,
  LinkGroupList,
  LinkGroupItem,
} from "@bejamas/registry/ui/link-group";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Link Group</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <LinkGroupComponent>
          <LinkGroupTitle>Company</LinkGroupTitle>
          <LinkGroupList>
            <LinkGroupItem>
              <a href="#">About</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">Blog</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">Careers</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">Contact</a>
            </LinkGroupItem>
          </LinkGroupList>
        </LinkGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Without Title">
        <LinkGroupComponent>
          <LinkGroupList>
            <LinkGroupItem>
              <a href="#">Documentation</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">API Reference</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">Changelog</a>
            </LinkGroupItem>
            <LinkGroupItem>
              <a href="#">Support</a>
            </LinkGroupItem>
          </LinkGroupList>
        </LinkGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Custom Styling">
        <LinkGroupComponent>
          <LinkGroupTitle class="text-primary">Resources</LinkGroupTitle>
          <LinkGroupList>
            <LinkGroupItem>
              <a href="#" class="text-muted-foreground hover:text-primary"
                >Tutorials</a
              >
            </LinkGroupItem>
          </LinkGroupList>
          <LinkGroupItem>
            <a href="#" class="text-muted-foreground hover:text-primary"
              >Examples</a
            >
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#" class="text-muted-foreground hover:text-primary"
              >Templates</a
            >
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#" class="text-muted-foreground hover:text-primary"
              >Showcase</a
            >
          </LinkGroupItem>
        </LinkGroupComponent>
      </KitchenSinkSection>
    </div>
  </section>

  <KitchenSinkSection title="Footer Layout">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <LinkGroupComponent>
        <LinkGroupTitle>Product</LinkGroupTitle>
        <LinkGroupList>
          <LinkGroupItem>
            <a href="#">Features</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Pricing</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Integrations</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Changelog</a>
          </LinkGroupItem>
        </LinkGroupList>
      </LinkGroupComponent>
      <LinkGroupComponent>
        <LinkGroupTitle>Company</LinkGroupTitle>
        <LinkGroupList>
          <LinkGroupItem>
            <a href="#">About</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Blog</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Careers</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Press</a>
          </LinkGroupItem>
        </LinkGroupList>
      </LinkGroupComponent>
      <LinkGroupComponent>
        <LinkGroupTitle>Resources</LinkGroupTitle>
        <LinkGroupList>
          <LinkGroupItem>
            <a href="#">Documentation</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Guides</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">API Reference</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Community</a>
          </LinkGroupItem>
        </LinkGroupList>
      </LinkGroupComponent>
      <LinkGroupComponent>
        <LinkGroupTitle>Legal</LinkGroupTitle>
        <LinkGroupList>
          <LinkGroupItem>
            <a href="#">Privacy</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Terms</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Cookie Policy</a>
          </LinkGroupItem>
          <LinkGroupItem>
            <a href="#">Licenses</a>
          </LinkGroupItem>
        </LinkGroupList>
      </LinkGroupComponent>
    </div>
  </KitchenSinkSection>
</KitchenSinkLayout>
