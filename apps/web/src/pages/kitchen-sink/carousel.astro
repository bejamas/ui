---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Carousel as CarouselComponent, CarouselSlide } from "@bejamas/registry/ui/carousel";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Carousel</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <CarouselComponent>
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 1
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 2
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 3
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 4
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 5
            </div></CarouselSlide
          >
        </CarouselComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Vertical">
        <CarouselComponent axis="y" class="h-64">
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl h-48 w-full flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 1
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl h-48 w-full flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 2
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl h-48 w-full flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 3
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl h-48 w-full flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 4
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl h-48 w-full flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 5
            </div></CarouselSlide
          >
        </CarouselComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Snap Proximity">
        <CarouselComponent snapType="proximity">
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 1
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 2
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 3
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 4
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-64 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 5
            </div></CarouselSlide
          >
        </CarouselComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Center Aligned">
        <CarouselComponent align="center">
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-48 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 1
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-48 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 2
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-48 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 3
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-48 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 4
            </div></CarouselSlide
          >
          <CarouselSlide
            ><div
              class="bg-muted rounded-xl aspect-[3/4] w-48 flex items-center justify-center text-muted-foreground font-medium"
            >
              Slide 5
            </div></CarouselSlide
          >
        </CarouselComponent>
      </KitchenSinkSection>
    </div>

    <KitchenSinkSection title="With Fade">
      <CarouselComponent fade>
        <CarouselSlide
          ><div
            class="bg-muted rounded-xl aspect-video w-full flex items-center justify-center text-muted-foreground font-medium text-2xl"
          >
            Slide 1
          </div></CarouselSlide
        >
        <CarouselSlide
          ><div
            class="bg-muted/80 rounded-xl aspect-video w-full flex items-center justify-center text-muted-foreground font-medium text-2xl"
          >
            Slide 2
          </div></CarouselSlide
        >
        <CarouselSlide
          ><div
            class="bg-muted/60 rounded-xl aspect-video w-full flex items-center justify-center text-muted-foreground font-medium text-2xl"
          >
            Slide 3
          </div></CarouselSlide
        >
      </CarouselComponent>
    </KitchenSinkSection>

    <KitchenSinkSection title="Multiple Items">
      <CarouselComponent>
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 1
          </div></CarouselSlide
        >
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 2
          </div></CarouselSlide
        >
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 3
          </div></CarouselSlide
        >
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 4
          </div></CarouselSlide
        >
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 5
          </div></CarouselSlide
        >
        <CarouselSlide class="w-1/3"
          ><div
            class="bg-muted rounded-xl aspect-video flex items-center justify-center text-muted-foreground font-medium"
          >
            Slide 6
          </div></CarouselSlide
        >
      </CarouselComponent>
    </KitchenSinkSection>
  </section>
</KitchenSinkLayout>
