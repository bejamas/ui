---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import {
  ButtonGroup as ButtonGroupComponent,
  ButtonGroupSeparator,
  ButtonGroupText,
} from "@bejamas/registry/ui/button-group";
import { Button } from "@bejamas/registry/ui/button";
import {
  BoldIcon,
  ItalicIcon,
  UnderlineIcon,
  ChevronDownIcon,
} from "@lucide/astro";
import AlignLeftIcon from "@/components/icons/AlignLeftIcon.astro";
import AlignCenterIcon from "@/components/icons/AlignCenterIcon.astro";
import AlignRightIcon from "@/components/icons/AlignRightIcon.astro";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Button Group</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Horizontal (Default)">
        <ButtonGroupComponent>
          <Button variant="outline">Left</Button>
          <Button variant="outline">Center</Button>
          <Button variant="outline">Right</Button>
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Vertical">
        <ButtonGroupComponent orientation="vertical">
          <Button variant="outline">Top</Button>
          <Button variant="outline">Middle</Button>
          <Button variant="outline">Bottom</Button>
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Sizes">
        <div class="space-y-4">
          <ButtonGroupComponent>
            <Button variant="outline" size="sm">Small</Button>
            <Button variant="outline" size="sm">Group</Button>
            <Button variant="outline" size="sm">Here</Button>
          </ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="outline">Default</Button>
            <Button variant="outline">Group</Button>
            <Button variant="outline">Here</Button>
          </ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="outline" size="lg">Large</Button>
            <Button variant="outline" size="lg">Group</Button>
            <Button variant="outline" size="lg">Here</Button>
          </ButtonGroupComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Icons">
        <ButtonGroupComponent>
          <Button variant="outline" size="icon"
            ><BoldIcon class="size-4" /></Button
          >
          <Button variant="outline" size="icon"
            ><ItalicIcon class="size-4" /></Button
          >
          <Button variant="outline" size="icon"
            ><UnderlineIcon class="size-4" /></Button
          >
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Split Button">
        <ButtonGroupComponent>
          <Button variant="secondary">Save</Button>
          <ButtonGroupSeparator />
          <Button variant="secondary" size="icon"
            ><ChevronDownIcon class="size-4" /></Button
          >
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Text">
        <ButtonGroupComponent>
          <ButtonGroupText>
            <BoldIcon class="size-4" />
            Formatting
          </ButtonGroupText>
          <Button variant="outline">Enable</Button>
          <Button variant="outline">Disable</Button>
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Nested">
        <ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="outline" size="icon"
              ><AlignLeftIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><AlignCenterIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><AlignRightIcon class="size-4" /></Button
            >
          </ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="outline" size="icon"
              ><BoldIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><ItalicIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><UnderlineIcon class="size-4" /></Button
            >
          </ButtonGroupComponent>
        </ButtonGroupComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="RTL">
        <div dir="rtl" class="flex flex-col items-end gap-4">
          <ButtonGroupComponent>
            <Button variant="outline" size="icon"
              ><BoldIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><ItalicIcon class="size-4" /></Button
            >
            <Button variant="outline" size="icon"
              ><UnderlineIcon class="size-4" /></Button
            >
          </ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="outline">Start</Button>
            <Button variant="outline">Middle</Button>
            <Button variant="outline">End</Button>
          </ButtonGroupComponent>
          <ButtonGroupComponent>
            <Button variant="secondary">Primary</Button>
            <ButtonGroupSeparator />
            <Button variant="secondary" size="icon">
              <ChevronDownIcon class="size-4" />
            </Button>
          </ButtonGroupComponent>
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
