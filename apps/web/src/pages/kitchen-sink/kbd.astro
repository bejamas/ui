---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Kbd as KbdComponent, KbdGroup } from "@bejamas/registry/ui/kbd";
import { Button } from "@bejamas/registry/ui/button";
import {
  Tooltip,
  TooltipTrigger,
  TooltipContent,
} from "@bejamas/registry/ui/tooltip";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Kbd</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <div class="flex items-center gap-3 flex-wrap">
          <KbdComponent>⌘</KbdComponent>
          <KbdComponent>⇧</KbdComponent>
          <KbdComponent>⌥</KbdComponent>
          <KbdComponent>⌃</KbdComponent>
          <KbdComponent>Ctrl</KbdComponent>
          <KbdComponent>Enter</KbdComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Key Combinations">
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-sm text-muted-foreground w-16">Copy</span>
            <KbdGroup><KbdComponent>⌘</KbdComponent><KbdComponent>C</KbdComponent></KbdGroup>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-sm text-muted-foreground w-16">Paste</span>
            <KbdGroup><KbdComponent>⌘</KbdComponent><KbdComponent>V</KbdComponent></KbdGroup>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-sm text-muted-foreground w-16">Palette</span>
            <KbdGroup><KbdComponent>⌘</KbdComponent><KbdComponent>⇧</KbdComponent><KbdComponent>P</KbdComponent></KbdGroup>
          </div>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="In Context">
        <p class="text-sm text-muted-foreground">
          Press <KbdComponent>⌘</KbdComponent><KbdComponent>K</KbdComponent> to open the command palette.
        </p>
      </KitchenSinkSection>

      <KitchenSinkSection title="In Button">
        <div class="flex items-center gap-3">
          <Button variant="outline">Accept <KbdComponent>⏎</KbdComponent></Button>
          <Button variant="outline">Save <KbdComponent>⌘</KbdComponent><KbdComponent>S</KbdComponent></Button>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="In Tooltip">
        <Tooltip>
          <TooltipTrigger asChild>
            <Button variant="outline">Save</Button>
          </TooltipTrigger>
          <TooltipContent>
            <span class="flex items-center gap-2"
              >Save <KbdGroup><KbdComponent>⌘</KbdComponent><KbdComponent>S</KbdComponent></KbdGroup></span
            >
          </TooltipContent>
        </Tooltip>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
