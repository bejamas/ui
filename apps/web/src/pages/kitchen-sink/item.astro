---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import {
  Item as ItemComponent,
  ItemContent,
  ItemTitle,
  ItemDescription,
  ItemActions,
  ItemMedia,
  ItemGroup,
  ItemSeparator,
} from "@bejamas/registry/ui/item";
import { Button } from "@bejamas/registry/ui/button";
import {
  Avatar,
  AvatarImage,
  AvatarFallback,
} from "@bejamas/registry/ui/avatar";
import { FileIcon, EllipsisIcon } from "@lucide/astro";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Item</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <ItemComponent>
          <ItemContent>
            <ItemTitle>Project Update</ItemTitle>
            <ItemDescription
              >Latest changes to the component library</ItemDescription
            >
          </ItemContent>
          <ItemActions>
            <Button variant="outline" size="sm">View</Button>
          </ItemActions>
        </ItemComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Icon">
        <ItemComponent>
          <ItemMedia>
            <FileIcon class="size-5 text-muted-foreground" />
          </ItemMedia>
          <ItemContent>
            <ItemTitle>README.md</ItemTitle>
            <ItemDescription>Updated 2 hours ago</ItemDescription>
          </ItemContent>
        </ItemComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Avatar">
        <ItemComponent>
          <ItemMedia>
            <Avatar>
              <AvatarImage src="https://github.com/shadcn.png" alt="User" />
              <AvatarFallback>TK</AvatarFallback>
            </Avatar>
          </ItemMedia>
          <ItemContent>
            <ItemTitle>Thom Krupa</ItemTitle>
            <ItemDescription>thom@bejamas.io</ItemDescription>
          </ItemContent>
        </ItemComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Actions">
        <ItemComponent>
          <ItemContent>
            <ItemTitle>Feature Request</ItemTitle>
            <ItemDescription>Add dark mode toggle to navigation</ItemDescription
            >
          </ItemContent>
          <ItemActions>
            <Button variant="outline" size="sm">Edit</Button>
            <Button variant="ghost" size="icon" class="size-8">
              <EllipsisIcon class="size-4" />
            </Button>
          </ItemActions>
        </ItemComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="Variants">
        <div class="space-y-3">
          <ItemComponent>
            <ItemContent>
              <ItemTitle>Default variant</ItemTitle>
              <ItemDescription>Standard item style</ItemDescription>
            </ItemContent>
          </ItemComponent>
          <ItemComponent variant="outline">
            <ItemContent>
              <ItemTitle>Outline variant</ItemTitle>
              <ItemDescription>With border styling</ItemDescription>
            </ItemContent>
          </ItemComponent>
          <ItemComponent variant="muted">
            <ItemContent>
              <ItemTitle>Muted variant</ItemTitle>
              <ItemDescription>Subtle background</ItemDescription>
            </ItemContent>
          </ItemComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Small Size">
        <div class="space-y-2">
          <ItemComponent size="sm">
            <ItemMedia
              ><FileIcon class="size-4 text-muted-foreground" /></ItemMedia
            >
            <ItemContent>
              <ItemTitle>index.ts</ItemTitle>
            </ItemContent>
          </ItemComponent>
          <ItemComponent size="sm">
            <ItemMedia
              ><FileIcon class="size-4 text-muted-foreground" /></ItemMedia
            >
            <ItemContent>
              <ItemTitle>utils.ts</ItemTitle>
            </ItemContent>
          </ItemComponent>
          <ItemComponent size="sm">
            <ItemMedia
              ><FileIcon class="size-4 text-muted-foreground" /></ItemMedia
            >
            <ItemContent>
              <ItemTitle>types.ts</ItemTitle>
            </ItemContent>
          </ItemComponent>
        </div>
      </KitchenSinkSection>
    </div>

    <KitchenSinkSection title="Item Group">
      <ItemGroup class="max-w-md">
        <ItemComponent>
          <ItemMedia>
            <Avatar>
              <AvatarFallback
                class="bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300"
                >NK</AvatarFallback
              >
            </Avatar>
          </ItemMedia>
          <ItemContent>
            <ItemTitle>New comment on your post</ItemTitle>
            <ItemDescription
              >Nick left a comment on "Getting Started"</ItemDescription
            >
          </ItemContent>
          <ItemActions>
            <span class="text-xs text-muted-foreground">2m ago</span>
          </ItemActions>
        </ItemComponent>
        <ItemSeparator />
        <ItemComponent>
          <ItemMedia>
            <Avatar>
              <AvatarFallback
                class="bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-300"
                >JD</AvatarFallback
              >
            </Avatar>
          </ItemMedia>
          <ItemContent>
            <ItemTitle>Pull request merged</ItemTitle>
            <ItemDescription>Jane merged PR #42 into main</ItemDescription>
          </ItemContent>
          <ItemActions>
            <span class="text-xs text-muted-foreground">15m ago</span>
          </ItemActions>
        </ItemComponent>
        <ItemSeparator />
        <ItemComponent>
          <ItemMedia>
            <Avatar>
              <AvatarFallback
                class="bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-300"
                >AB</AvatarFallback
              >
            </Avatar>
          </ItemMedia>
          <ItemContent>
            <ItemTitle>Deployment successful</ItemTitle>
            <ItemDescription
              >Production build deployed to vercel</ItemDescription
            >
          </ItemContent>
          <ItemActions>
            <span class="text-xs text-muted-foreground">1h ago</span>
          </ItemActions>
        </ItemComponent>
        <ItemSeparator />
        <ItemComponent>
          <ItemMedia>
            <Avatar>
              <AvatarFallback
                class="bg-amber-100 text-amber-700 dark:bg-amber-900 dark:text-amber-300"
                >TK</AvatarFallback
              >
            </Avatar>
          </ItemMedia>
          <ItemContent>
            <ItemTitle>New team member</ItemTitle>
            <ItemDescription>Tom joined the engineering team</ItemDescription>
          </ItemContent>
          <ItemActions>
            <span class="text-xs text-muted-foreground">3h ago</span>
          </ItemActions>
        </ItemComponent>
      </ItemGroup>
    </KitchenSinkSection>
  </section>
</KitchenSinkLayout>
