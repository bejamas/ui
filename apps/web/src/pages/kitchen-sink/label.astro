---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Label as LabelComponent } from "@bejamas/registry/ui/label";
import { Input } from "@bejamas/registry/ui/input";
import { Checkbox } from "@bejamas/registry/ui/checkbox";
import { Switch } from "@bejamas/registry/ui/switch";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Label</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic">
        <LabelComponent>Username</LabelComponent>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Input">
        <div class="space-y-2">
          <LabelComponent for="label-input">Email</LabelComponent>
          <Input id="label-input" type="email" placeholder="you@example.com" />
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Checkbox">
        <div class="flex items-center gap-2">
          <Checkbox id="label-checkbox" />
          <LabelComponent for="label-checkbox">Accept terms and conditions</LabelComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Switch">
        <div class="flex items-center gap-2">
          <Switch id="label-switch" />
          <LabelComponent for="label-switch">Enable notifications</LabelComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Disabled">
        <div class="space-y-2">
          <LabelComponent
            for="label-disabled"
            class="peer-disabled:cursor-not-allowed peer-disabled:opacity-70"
            >Disabled field</LabelComponent
          >
          <Input id="label-disabled" disabled placeholder="Cannot edit" />
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Required">
        <div class="space-y-2">
          <LabelComponent for="label-required"
            >Name <span class="text-destructive">*</span></LabelComponent
          >
          <Input id="label-required" required placeholder="Enter your name" />
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
