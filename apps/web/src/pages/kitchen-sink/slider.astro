---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Slider } from "@bejamas/registry/ui/slider";
import { Label } from "@bejamas/registry/ui/label";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Slider</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Basic Slider">
        <Label>Basic Slider (default value: 50)</Label>
        <Slider class="w-full" defaultValue={[50]} max={100} />
      </KitchenSinkSection>

      <KitchenSinkSection title="Range Slider">
        <Label>Range Slider (values: 25, 75)</Label>
        <Slider class="w-full" defaultValue={[25, 75]} max={100} />
      </KitchenSinkSection>

      <KitchenSinkSection title="Vertical Slider">
        <Label>Vertical Slider</Label>
        <div class="h-48">
          <Slider class="h-full" orientation="vertical" defaultValue={[50]} max={100} />
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Disabled Slider">
        <Label>Disabled Slider</Label>
        <Slider class="w-full" defaultValue={[50]} max={100} disabled />
      </KitchenSinkSection>

      <KitchenSinkSection title="Step Slider">
        <Label>Step Slider (step: 10)</Label>
        <Slider class="w-full" defaultValue={[50]} max={100} step={10} />
      </KitchenSinkSection>

      <KitchenSinkSection title="Custom Min/Max">
        <Label>Custom Min/Max (min: -50, max: 50, value: 0)</Label>
        <Slider class="w-full" defaultValue={[0]} min={-50} max={50} />
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
