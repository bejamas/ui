---
import KitchenSinkLayout from "@/components/KitchenSinkLayout.astro";
import KitchenSinkSection from "@/components/KitchenSinkSection.astro";
import { Badge as BadgeComponent } from "@bejamas/registry/ui/badge";
import { CheckIcon, XIcon, AlertTriangleIcon, InfoIcon } from "@lucide/astro";
---

<KitchenSinkLayout>
  <section class="max-w-5xl mx-auto py-20 px-5 space-y-12">
    <h1 class="text-3xl font-bold mb-10">Badge</h1>

    <div class="grid md:grid-cols-2 gap-x-8 gap-y-12">
      <KitchenSinkSection title="Variants">
        <div class="flex items-center gap-2 flex-wrap">
          <BadgeComponent>Default</BadgeComponent>
          <BadgeComponent variant="secondary">Secondary</BadgeComponent>
          <BadgeComponent variant="destructive">Destructive</BadgeComponent>
          <BadgeComponent variant="outline">Outline</BadgeComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Pill Shape">
        <div class="flex items-center gap-2 flex-wrap">
          <BadgeComponent class="rounded-full">Default</BadgeComponent>
          <BadgeComponent variant="secondary" class="rounded-full">Secondary</BadgeComponent>
          <BadgeComponent variant="destructive" class="rounded-full">Destructive</BadgeComponent>
          <BadgeComponent variant="outline" class="rounded-full">Outline</BadgeComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="With Icons">
        <div class="flex items-center gap-2 flex-wrap">
          <BadgeComponent>
            <CheckIcon class="size-3" />
            Success
          </BadgeComponent>
          <BadgeComponent variant="destructive">
            <XIcon class="size-3" />
            Error
          </BadgeComponent>
          <BadgeComponent variant="secondary">
            <AlertTriangleIcon class="size-3" />
            Warning
          </BadgeComponent>
          <BadgeComponent variant="outline">
            <InfoIcon class="size-3" />
            Info
          </BadgeComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="As Link">
        <div class="flex items-center gap-2 flex-wrap">
          <a href="#badge-link">
            <BadgeComponent>Clickable Badge</BadgeComponent>
          </a>
          <a href="#badge-link">
            <BadgeComponent variant="outline">Link Badge</BadgeComponent>
          </a>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Counter Badges">
        <div class="flex items-center gap-3 flex-wrap">
          <BadgeComponent>1</BadgeComponent>
          <BadgeComponent variant="secondary">24</BadgeComponent>
          <BadgeComponent variant="destructive">99+</BadgeComponent>
          <BadgeComponent variant="outline">0</BadgeComponent>
        </div>
      </KitchenSinkSection>

      <KitchenSinkSection title="Custom Colors">
        <div class="flex items-center gap-2 flex-wrap">
          <BadgeComponent
            class="bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 hover:bg-blue-200 dark:hover:bg-blue-800"
            >Info</BadgeComponent
          >
          <BadgeComponent
            class="bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200 hover:bg-amber-200 dark:hover:bg-amber-800"
            >Warning</BadgeComponent
          >
          <BadgeComponent
            class="bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 hover:bg-green-200 dark:hover:bg-green-800"
            >Success</BadgeComponent
          >
          <BadgeComponent
            class="bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200 hover:bg-purple-200 dark:hover:bg-purple-800"
            >New</BadgeComponent
          >
        </div>
      </KitchenSinkSection>
    </div>
  </section>
</KitchenSinkLayout>
