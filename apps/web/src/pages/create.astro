---
import {
  DEFAULT_DESIGN_SYSTEM_CONFIG,
  STYLES,
  encodePreset,
  getCompiledStyleCss,
} from "@bejamas/create-config/server";
import { buildCreateDocsRootInitScript } from "@/utils/create-docs-shell";
import { buildDesignSystemThemeCss } from "@/utils/themes/design-system-adapter";
import {
  buildCreatePreviewUrl,
  parseCreateSearchParams,
  resolveCreatePreviewTarget,
  resolveCreateThemeRef,
} from "@/utils/create";
import {
  parseThemeCookie,
  PRESET_COOKIE_NAME,
  THEME_REF_COOKIE_NAME,
} from "@/utils/themes/theme-cookie";
import { getThemeOverridesByRef } from "@/utils/themes/create-theme.server";
import { buildWindowAssignmentInlineScript } from "@/utils/inline-script";
import CreateCustomizer from "@/components/create/CreateCustomizer.astro";
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

const cookieThemeId = Astro.cookies.has(PRESET_COOKIE_NAME)
  ? parseThemeCookie(Astro.cookies.get(PRESET_COOKIE_NAME)!.value).id
  : null;
const result = parseCreateSearchParams(Astro.url.searchParams, {
  fallbackPreset: cookieThemeId,
});
const config = result.success ? result.data : DEFAULT_DESIGN_SYSTEM_CONFIG;
const cookieThemeRef = Astro.cookies.get(THEME_REF_COOKIE_NAME)?.value ?? null;
const requestedThemeRef = resolveCreateThemeRef(Astro.url.searchParams, {
  fallbackThemeRef: cookieThemeRef,
});
const themeOverrides = await getThemeOverridesByRef(requestedThemeRef);
const themeRef = themeOverrides ? requestedThemeRef : null;
const preset = encodePreset(config);
const previewTarget = resolveCreatePreviewTarget(Astro.url.searchParams);
const previewUrl = buildCreatePreviewUrl(config, preset, {
  previewTarget,
  themeRef,
});
const compiledStyleCss = await getCompiledStyleCss(config.style);
const docsRootInitScript = buildCreateDocsRootInitScript(config.style);
const styleCssByStyle = Object.fromEntries(
  await Promise.all(
    STYLES.map(async (style) => [
      style.name,
      await getCompiledStyleCss(style.name),
    ]),
  ),
);
const createPayloadScript = buildWindowAssignmentInlineScript(
  "__BEJAMAS_CREATE__",
  {
    styleCssByStyle,
    initialThemeRef: themeRef,
    initialThemeOverrides: themeOverrides,
  },
);
---

<style is:global>
  @import "../styles/globals.css";
</style>
<script is:inline set:html={docsRootInitScript} />
<style
  id="create-page-theme-css"
  set:html={buildDesignSystemThemeCss(config, themeOverrides)}
></style>
<style id="create-page-style-css" set:html={compiledStyleCss}></style>

<StarlightPage
  hasSidebar={false}
  frontmatter={{
    title: "Create",
    description:
      "Tune the design system, preview it live, and copy the Astro init command or shareable preset code.",
    template: "splash",
    tableOfContents: false,
  }}
>
  <div class:list={["not-content create-page-root"]} data-create-page>
    <main class="mx-auto flex max-w-full flex-col gap-6 px-0">
      <div
        class="grid gap-6 xl:min-h-[var(--create-preview-height)] xl:grid-cols-[260px_minmax(0,1fr)] xl:items-stretch"
      >
        <CreateCustomizer
          config={config}
          preset={preset}
          themeRef={themeRef}
          themeOverrides={themeOverrides}
        />

        <iframe
          src={previewUrl}
          title="Create preview"
          class="min-h-[780px] w-full rounded-[24px] border border-border bg-background xl:h-[var(--create-preview-height)] xl:min-h-0"
          data-preview-frame></iframe>
      </div>
    </main>
  </div>
</StarlightPage>

<script is:inline set:html={createPayloadScript} />
<script>
  import "@/scripts/create-page.ts";
</script>

<style is:global>
  @reference "tailwindcss";

  .create-page-root {
    --create-page-inset: var(--sl-content-pad-x);
    --create-preview-height: calc(
      100dvh - var(--sl-nav-height) - var(--create-page-inset)
    );
    --create-sidebar-height: var(--create-preview-height);
  }

  .content-panel {
    @apply border-0 pt-0 pb-0 first-of-type:hidden;
  }

  .content-panel h1 {
    @apply text-5xl font-medium text-left;
  }

  .main-frame-splash::before,
  .kudos {
    display: none;
  }

  .sl-container {
    @apply max-w-full;
  }

  .sl-markdown-content {
    @apply mx-auto mt-0 max-w-full pt-0;
  }

  .main-frame {
    padding-inline: 0;
  }

  .main-pane > main {
    @apply pb-0;
  }

  footer.sl-flex {
    @apply hidden;
  }

  :root[data-create-docs-themed] [data-create-customizer-stable],
  :root[data-create-docs-themed] [data-create-main-menu-content],
  :root[data-create-docs-themed] [data-create-picker-content] {
    font-family: "Geist Variable", sans-serif;
    --radius: 0.625rem;
  }

  :root[data-create-docs-themed] [data-create-customizer-stable] .cn-switch {
    @apply !h-5 !w-8 !rounded-full !border-transparent !bg-white/15 !shadow-none;
  }

  [data-create-form-main] {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 1.5);
  }

  .create-customizer-actions {
    display: flex;
    flex-direction: column;
  }

  :root[data-create-docs-themed]
    [data-create-customizer-stable]
    .cn-switch-thumb {
    @apply !rounded-full !bg-[#171412] dark:!bg-[#171412] shadow-[0_1px_2px_rgba(0,0,0,0.34)];
  }

  :root[data-create-docs-themed]
    [data-create-customizer-stable]
    input:checked
    ~ .cn-switch {
    @apply !bg-white;
  }

  :root[data-create-docs-themed]
    [data-create-customizer-stable]
    input:checked
    ~ .cn-switch-thumb {
    @apply !bg-[#201b18];
  }

  :root[data-create-docs-themed]
    :is([data-create-main-menu-content], [data-create-picker-content])
    [data-slot="dropdown-menu-item"][data-highlighted],
  :root[data-create-docs-themed]
    :is([data-create-main-menu-content], [data-create-picker-content])
    [data-slot="dropdown-menu-item"][data-selected] {
    background: rgba(255, 255, 255, 0.06) !important;
    color: rgba(255, 255, 255, 0.92) !important;
  }

  :root[data-create-docs-themed]
    :is([data-create-main-menu-content], [data-create-picker-content])
    [data-slot="dropdown-menu-item"][data-highlighted]
    :is(
      svg,
      [data-create-picker-item-label],
      [data-slot="dropdown-menu-shortcut"]
    ),
  :root[data-create-docs-themed]
    :is([data-create-main-menu-content], [data-create-picker-content])
    [data-slot="dropdown-menu-item"][data-selected]
    :is(
      svg,
      [data-create-picker-item-label],
      [data-slot="dropdown-menu-shortcut"]
    ) {
    color: inherit !important;
  }
</style>
