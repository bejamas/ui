---
import {
  catalogs,
  DEFAULT_LANGUAGE,
  getDocumentDirection,
  getDocumentLanguage,
  getCompiledStyleCss,
} from "@bejamas/create-config/server";
import CreatePreviewSurface from "@/components/create/CreatePreviewSurface.astro";
import { buildDesignSystemThemeCss } from "@/utils/themes/design-system-adapter";
import { buildIframeThemeSyncInlineScript } from "@/utils/themes/iframe-theme-sync";
import { parseCreateSearchParams, resolveCreateThemeRef } from "@/utils/create";
import { getCreatePickerSelectedOption } from "@/utils/create-sidebar";
import { getCreatePreviewCopy } from "@/utils/create-preview-i18n";
import { getThemeOverridesByRef } from "@/utils/themes/create-theme.server";
import themeFontsStylesheet from "@/styles/theme-fonts.css?url";

const result = parseCreateSearchParams(Astro.url.searchParams);
const config = result.success ? result.data : undefined;
const requestedThemeRef = resolveCreateThemeRef(Astro.url.searchParams);
const themeOverrides = await getThemeOverridesByRef(requestedThemeRef);
const currentConfig = config ?? undefined;
const themeCss = currentConfig
  ? buildDesignSystemThemeCss(currentConfig, themeOverrides)
  : "";
const compiledStyleCss = currentConfig
  ? await getCompiledStyleCss(currentConfig.style)
  : "";
const iframeThemeSyncScript = buildIframeThemeSyncInlineScript();
const currentRadiusLabel = currentConfig
  ? (getCreatePickerSelectedOption("radius", currentConfig)?.label ??
    currentConfig.radius)
  : undefined;
const currentLanguage = currentConfig
  ? getDocumentLanguage(currentConfig)
  : DEFAULT_LANGUAGE;
const currentDirection = currentConfig
  ? getDocumentDirection(currentConfig)
  : "ltr";
const previewCopy = getCreatePreviewCopy(currentLanguage);
---

<!doctype html>
<html lang={currentLanguage} dir={currentDirection}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={iframeThemeSyncScript} />
    <link rel="stylesheet" href={themeFontsStylesheet} />
    <style is:global>
      @import "@bejamas/ui/styles/globals.css";
    </style>
    <style id="create-theme-css" set:html={themeCss}></style>
    <style id="create-style-css" set:html={compiledStyleCss}></style>
  </head>
  <body class:list={currentConfig ? [`style-${currentConfig.style}`] : []}>
    {
      currentConfig ? (
        <CreatePreviewSurface
          iconLibrary={currentConfig.iconLibrary}
          iconLibraryLabel={
            catalogs.iconLibraries.find(
              (library) => library.name === currentConfig.iconLibrary,
            )?.label ?? currentConfig.iconLibrary
          }
          styleLabel={
            catalogs.styles.find((style) => style.name === currentConfig.style)
              ?.title ?? currentConfig.style
          }
          fontLabel={
            catalogs.fonts.find(
              (font) => font.name === `font-${currentConfig.font}`,
            )?.title ?? currentConfig.font
          }
          templateLabel={currentConfig.template}
          radiusLabel={currentRadiusLabel}
          menuColorLabel={currentConfig.menuColor}
          menuInverted={currentConfig.menuColor === "inverted"}
          copy={previewCopy}
        />
      ) : (
        <div class="grid min-h-screen place-items-center bg-background text-foreground">
          <p class="text-sm text-muted-foreground">Invalid preview config.</p>
        </div>
      )
    }
    <script
      define:vars={{
        styleCssByStyle: Object.fromEntries(
          await Promise.all(
            catalogs.styles.map(async (style) => [
              style.name,
              await getCompiledStyleCss(style.name),
            ]),
          ),
        ),
        initialThemeOverrides: themeOverrides,
      }}
    >
      window.__BEJAMAS_CREATE_PREVIEW__ = {
        styleCssByStyle,
        initialThemeOverrides,
      };
    </script>
    <script>
      import "@/scripts/create-preview.ts";
    </script>
  </body>
</html>
