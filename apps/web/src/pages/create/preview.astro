---
import {
  catalogs,
  getCompiledStyleCss,
  isInvertedMenuColor,
  isTranslucentMenuColor,
} from "@bejamas/create-config/server";
import CreatePreviewSurface from "@/components/create/CreatePreviewSurface.astro";
import { buildDesignSystemThemeCss } from "@/utils/themes/design-system-adapter";
import { buildIframeThemeSyncInlineScript } from "@/utils/themes/iframe-theme-sync";
import { getCreatePickerSelectedOption } from "@/utils/create-sidebar";
import { getCreatePreviewCopy } from "@/utils/create-preview-i18n";
import { getDefaultCreateBootstrapState } from "@/utils/create-bootstrap";
import { buildWindowAssignmentInlineScript } from "@/utils/inline-script";
import themeFontsStylesheet from "@/styles/theme-fonts.css?url";
const { config } = getDefaultCreateBootstrapState();
const themeCss = buildDesignSystemThemeCss(config);
const compiledStyleCss = await getCompiledStyleCss(config.style);
const iframeThemeSyncScript = buildIframeThemeSyncInlineScript();
const currentRadiusLabel =
  getCreatePickerSelectedOption("radius", config)?.label ?? config.radius;
const previewCopy = getCreatePreviewCopy("en");
const styleCssByStyle = Object.fromEntries(
  await Promise.all(
    catalogs.styles.map(async (style) => [
      style.name,
      await getCompiledStyleCss(style.name),
    ]),
  ),
);
const previewPayloadScript = buildWindowAssignmentInlineScript(
  "__BEJAMAS_CREATE_PREVIEW__",
  {
    styleCssByStyle,
  },
);
---

<!doctype html>
<html lang="en" dir="ltr" class="bg-background">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={iframeThemeSyncScript} />
    <link rel="stylesheet" href={themeFontsStylesheet} />
    <style is:global>
      @import "../../styles/globals.css";
    </style>
    <style is:global>
      body[data-create-preview-pending] {
        visibility: hidden;
      }
    </style>
    <style id="create-theme-css" set:html={themeCss}></style>
    <style id="create-style-css" set:html={compiledStyleCss}></style>
  </head>
  <body
    class:list={[`style-${config.style}`, "bg-background"]}
    data-create-preview-pending
    data-controller="create-preview"
    data-action="message@window->create-preview#receiveMessage keydown.meta+p@document->create-preview#openNavigateShortcut keydown.ctrl+p@document->create-preview#openNavigateShortcut"
  >
    <div data-create-preview-surface>
      <CreatePreviewSurface
        iconLibrary={config.iconLibrary}
        iconLibraryLabel={
          catalogs.iconLibraries.find((library) => library.name === config.iconLibrary)
            ?.label ?? config.iconLibrary
        }
        styleLabel={
          catalogs.styles.find((style) => style.name === config.style)?.title ??
          config.style
        }
        fontLabel={
          catalogs.fonts.find((font) => font.name === `font-${config.font}`)?.title ??
          config.font
        }
        fontHeadingLabel={
          config.fontHeading === "inherit"
            ? null
            : (catalogs.fonts.find(
                (font) => font.name === `font-${config.fontHeading}`,
              )?.title ?? config.fontHeading)
        }
        radiusLabel={currentRadiusLabel}
        menuColorLabel={
          getCreatePickerSelectedOption("menuColor", config)?.label ?? config.menuColor
        }
        menuInverted={isInvertedMenuColor(config.menuColor)}
        menuTranslucent={isTranslucentMenuColor(config.menuColor)}
        copy={previewCopy}
      />
    </div>
    <div
      class="hidden grid min-h-screen place-items-center bg-background text-foreground"
      data-create-preview-invalid
    >
      <p class="text-sm text-muted-foreground">Invalid preview config.</p>
    </div>
    <script is:inline set:html={previewPayloadScript} />
    <script>
      import "@/stimulus/create";
    </script>
  </body>
</html>
