---
import { Button } from "@bejamas/ui/components/button";
import { ButtonGroup } from "@bejamas/ui/components/button-group";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
} from "@bejamas/ui/components/dropdown-menu";
import {
  Tooltip,
  TooltipTrigger,
  TooltipContent,
} from "@bejamas/ui/components/tooltip";
// Import Dialog and Accordion to ensure their scripts are included for MDX pages
import { Dialog, DialogContent } from "@bejamas/ui/components/dialog";
import {
  Accordion,
  AccordionItem,
  AccordionTrigger,
  AccordionContent,
} from "@bejamas/ui/components/accordion";
import {
  Collapsible,
  CollapsibleTrigger,
  CollapsibleContent,
} from "@bejamas/ui/components/collapsible";
import {
  Slider,
  SliderTrack,
  SliderRange,
  SliderThumb,
} from "@bejamas/ui/components/slider";
import { Toggle } from "@bejamas/ui/components/toggle";
import {
  ToggleGroup,
  ToggleGroupItem,
} from "@bejamas/ui/components/toggle-group";

import {
  ArrowRight,
  ArrowLeft,
  ChevronDown,
  Copy,
  Check,
} from "@lucide/astro";

import MarkdownIcon from "./icons/Markdown.astro";

import {
  NavigationMenu,
  NavigationMenuList,
  NavigationMenuItem,
  NavigationMenuTrigger,
} from "@bejamas/ui/components/navigation-menu";

import {
  Popover,
  PopoverContent,
  PopoverTrigger,
} from "@bejamas/ui/components/popover";

import Icon from "./icons/Icon.astro";
import { hasMarkdownSource } from "../utils/docsMarkdown";

const { dir, pagination, entry } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === "rtl";
const PAGE_ACTION_PROMPT = "Read {url}. I want to ask questions about it.";

interface OptionsProps {
  label: string;
  href: string;
  id: "chatgpt" | "claude";
}

const currentPath = Astro.url.pathname.replace(/\/$/, "");
const currentUrl = Astro.url.href;
const componentMatch = Astro.url.pathname.match(/^\/components\/([^/]+)\/?$/);
const currentComponent = componentMatch ? componentMatch[1] : null;
const showMarkdownActions = hasMarkdownSource(Astro.url.pathname);
const prompt = PAGE_ACTION_PROMPT.replace("{url}", currentUrl);
const encodedPrompt = encodeURIComponent(prompt);

const options: OptionsProps[] = [
  {
    label: "Open in ChatGPT",
    href: `https://chatgpt.com/?q=${encodedPrompt}`,
    id: "chatgpt",
  },
  {
    label: "Open in Claude",
    href: `https://claude.ai/new?q=${encodedPrompt}`,
    id: "claude",
  },
];
---

<div
  class:list={[
    "sl-bejamas-docs-title",
    entry.data.template === "splash" && "mt-10",
    entry.data.template === "splash" && "px-0 sm:px-6 md:px-8",
  ]}
>
  <div class="sl-bejamas-docs-title-main">
    <div class="flex items-center">
      <h1 id="_top" class="tracking-tight">
        {Astro.locals.starlightRoute.entry.data.title}
      </h1>

      {
        currentComponent && (
          <Tooltip class="ml-4" delay={300}>
            <TooltipTrigger asChild class="flex">
              <a
                href={`https://github.com/bejamas/ui/tree/main/packages/ui/src/components/${currentComponent}`}
                class="text-muted-foreground flex items-center justify-center h-6 w-6"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="currentColor"
                  viewBox="0 0 256 256"
                >
                  <path d="M216,104v8a56.06,56.06,0,0,1-48.44,55.47A39.8,39.8,0,0,1,176,192v40a8,8,0,0,1-8,8H104a8,8,0,0,1-8-8V216H72a40,40,0,0,1-40-40A24,24,0,0,0,8,152a8,8,0,0,1,0-16,40,40,0,0,1,40,40,24,24,0,0,0,24,24H96v-8a39.8,39.8,0,0,1,8.44-24.53A56.06,56.06,0,0,1,56,112v-8a58.14,58.14,0,0,1,7.69-28.32A59.78,59.78,0,0,1,69.07,28,8,8,0,0,1,76,24a59.75,59.75,0,0,1,48,24h24a59.75,59.75,0,0,1,48-24,8,8,0,0,1,6.93,4,59.74,59.74,0,0,1,5.37,47.68A58,58,0,0,1,216,104Z" />
                </svg>
              </a>
            </TooltipTrigger>
            <TooltipContent>
              <p>Open in GitHub</p>
            </TooltipContent>
          </Tooltip>
        )
      }
      {
        entry.data.figmaUrl && (
          <Tooltip class="ml-2" delay={300}>
            <TooltipTrigger asChild class="flex">
              <a
                href={entry.data.figmaUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center h-6 w-6"
              >
                <svg
                  fill="none"
                  height="20"
                  viewBox="0 0 38 57"
                  width="20"
                  xmlns="http://www.w3.org/2000/svg"
                  class="text-lg grayscale"
                >
                  <>
                    <path
                      d="M19 28.5a9.5 9.5 0 1 1 19 0 9.5 9.5 0 0 1-19 0Z"
                      fill="#1ABCFE"
                    />
                    <path
                      d="M0 47.5A9.5 9.5 0 0 1 9.5 38H19v9.5a9.5 9.5 0 1 1-19 0Z"
                      fill="#0ACF83"
                    />
                    <path
                      d="M19 0v19h9.5a9.5 9.5 0 1 0 0-19H19Z"
                      fill="#FF7262"
                    />
                    <path
                      d="M0 9.5A9.5 9.5 0 0 0 9.5 19H19V0H9.5A9.5 9.5 0 0 0 0 9.5Z"
                      fill="#F24E1E"
                    />
                    <path
                      d="M0 28.5A9.5 9.5 0 0 0 9.5 38H19V19H9.5A9.5 9.5 0 0 0 0 28.5Z"
                      fill="#A259FF"
                    />
                  </>
                </svg>
              </a>
            </TooltipTrigger>
            <TooltipContent>
              <p>Open in Figma</p>
            </TooltipContent>
          </Tooltip>
        )
      }
    </div>

    {
      entry.data.description && (
        <p class="sl-bejamas-description">{entry.data.description}</p>
      )
    }
  </div>

  {
    showMarkdownActions && (
      <div class="sl-bejamas-docs-title-buttons">
        <ButtonGroup>
          <Button
            variant="outline"
            size="sm"
            id="copy-markdown"
            data-path={currentPath}
          >
            <Copy id="copy-icon" class="size-3.5" />
            <Check id="check-icon" class="size-3.5 hidden" />
            Copy page
          </Button>
          <DropdownMenu>
            <Button
              variant="outline"
              class="rounded-l-none border-l-0 px-1"
              size="sm"
              data-slot="dropdown-menu-trigger"
            >
              <ChevronDown class="size-4" />
            </Button>
            <DropdownMenuContent align="end">
              <DropdownMenuItem class="p-0">
                <Button
                  as="a"
                  href={`${currentPath}.md`}
                  variant="ghost"
                  size="sm"
                  class="w-full justify-start rounded-sm hover:bg-transparent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <MarkdownIcon />
                  <span>View as Markdown</span>
                </Button>
              </DropdownMenuItem>
              {options.map((option) => (
                <DropdownMenuItem class="p-0">
                  <Button
                    as="a"
                    href={option.href}
                    variant="ghost"
                    size="sm"
                    class="w-full justify-start rounded-sm hover:bg-transparent"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Icon icon={option.id} />
                    <span>{option.label}</span>
                  </Button>
                </DropdownMenuItem>
              ))}
            </DropdownMenuContent>
          </DropdownMenu>
        </ButtonGroup>
        {prev && (
          <Button
            as="a"
            href={isRtl ? next.href : prev.href}
            variant="outline"
            size="icon-sm"
          >
            <ArrowLeft class="size-3.5" />
          </Button>
        )}
        {next && (
          <Button
            as="a"
            href={isRtl ? prev.href : next.href}
            variant="outline"
            size="icon-sm"
          >
            <ArrowRight class="size-3.5" />
          </Button>
        )}
      </div>
    )
  }

</div>

<!-- Hidden component renders to ensure their scripts are included for MDX pages -->
<div style="display: none;" aria-hidden="true" data-component-scripts>
  <Dialog>
    <DialogContent showCloseButton={false} />
  </Dialog>
  <Accordion>
    <AccordionItem>
      <AccordionTrigger />
      <AccordionContent />
    </AccordionItem>
  </Accordion>
  <Collapsible>
    <CollapsibleTrigger>
      <Button variant="ghost">Toggle</Button>
    </CollapsibleTrigger>
    <CollapsibleContent> Hidden content here </CollapsibleContent>
  </Collapsible>
  <Tooltip>
    <TooltipTrigger>
      <Button variant="ghost">Toggle</Button>
    </TooltipTrigger>
    <TooltipContent>
      <p>Hidden content here</p>
    </TooltipContent>
  </Tooltip>
  <NavigationMenu>
    <NavigationMenuList>
      <NavigationMenuItem>
        <NavigationMenuTrigger>Toggle</NavigationMenuTrigger>
      </NavigationMenuItem>
    </NavigationMenuList>
  </NavigationMenu>
  <Slider>
    <SliderTrack>
      <SliderRange />
    </SliderTrack>
    <SliderThumb />
  </Slider>
  <Toggle />
  <ToggleGroup>
    <ToggleGroupItem value="left" aria-label="Align left">
      left
    </ToggleGroupItem>
  </ToggleGroup>

  <Popover>
    <PopoverTrigger>
      <Button variant="ghost">Toggle</Button>
    </PopoverTrigger>
    <PopoverContent>
      <p>Hidden content here</p>
    </PopoverContent>
  </Popover>
</div>

<style>
  @layer bejamas {
    .sl-bejamas-docs-title {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: calc(var(--spacing) * 9);
      align-items: flex-start;
      gap: 1rem;
    }
    .sl-bejamas-docs-title-main {
      flex: 1 1 0%;
      min-width: 0;
    }
    .sl-bejamas-docs-title-buttons {
      gap: 0.5rem;
      display: none;
      flex-shrink: 0;
      align-self: flex-start;
    }

    @media (min-width: 50rem) {
      .sl-bejamas-docs-title-buttons {
        display: flex;
      }
    }
  }

  .sl-bejamas-description {
    color: var(--muted-foreground);
    text-wrap: balance;
    margin-top: calc(var(--spacing) * 4);
    margin-bottom: calc(var(--spacing) * 2);
    width: 100%;
    max-width: 52ch;
  }

  @layer starlight.core {
    h1 {
      font-size: 1.875rem;
      line-height: 1.2;
      font-weight: 500;
      color: var(--sl-color-white);
    }

    /* @media (min-width: 50rem) {
      h1 {
        font-size: 1rem;
        line-height: calc(2.5 / 2.25);
      }
    } */
  }
</style>

<script>
  const copyButton = document.querySelector(
    "#copy-markdown",
  ) as HTMLButtonElement;
  const copyIcon = document.querySelector("#copy-icon") as SVGElement;
  const checkIcon = document.querySelector("#check-icon") as SVGElement;
  let copyButttonClass: "copied" | "error" = "copied";

  copyButton?.addEventListener("click", async () => {
    try {
      copyButton.disabled = true;
      copyButttonClass = "copied";

      const currentPath = copyButton.dataset.path;

      if (!currentPath) {
        throw new Error("Missing page path");
      }

      const mdPath = `${currentPath}.md`;

      const res = await fetch(mdPath);

      if (!res.ok) {
        throw new Error(`Failed to fetch markdown: ${res.status}`);
      }

      const contentForClipboard = await res.text();

      await navigator.clipboard.writeText(contentForClipboard);

      // Show success icon
      copyIcon?.classList.add("hidden");
      checkIcon?.classList.remove("hidden");

      // Reset to copy icon after 2 seconds
      setTimeout(() => {
        copyIcon?.classList.remove("hidden");
        checkIcon?.classList.add("hidden");
      }, 2000);
    } catch (error) {
      console.error(error);
      copyButttonClass = "error";
    } finally {
      copyButton.classList.add(copyButttonClass);
      copyButton.disabled = false;

      setTimeout(() => {
        copyButton.classList.remove(copyButttonClass);
      }, 3000);
    }
  });
</script>
