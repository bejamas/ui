---
import "@/styles/blocks.css";
import "@bejamas/ui/styles/globals.css";
import { buildThemeChoiceBootstrapInlineScript } from "starlight-theme-bejamas/lib/theme-choice";

interface Props {
  theme?: string;
  title?: string;
}

const { theme = "current-theme", title } = Astro.props;
const themeChoiceBootstrapScript = buildThemeChoiceBootstrapInlineScript();
---

<html lang="en" class="bg-background">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, nofollow" />
    {title && <title>{title}</title>}
    <script is:inline set:html={themeChoiceBootstrapScript} />
  </head>
  <body class="antialiased bg-background">
    <link rel="stylesheet" href={`/r/themes/${theme}.css`} />

    <slot />

    <script>
      import {
        getStoredPreset,
        PRESET_CHANGE_EVENT,
        PRESET_STORAGE_KEY,
      } from "../utils/themes/preset-store.ts";
      import {
        resolveGradientThemeFromPresetId,
        syncGradientImages,
      } from "../utils/themes/gradient-image-runtime.ts";

      function syncPreviewGradientImages(themeOverride?: string | null) {
        const theme =
          themeOverride ?? resolveGradientThemeFromPresetId(getStoredPreset());
        if (!theme) {
          return;
        }

        syncGradientImages({ theme });
      }

      syncPreviewGradientImages();

      window.addEventListener("storage", (event) => {
        if (event.key === PRESET_STORAGE_KEY) {
          syncPreviewGradientImages(
            resolveGradientThemeFromPresetId(event.newValue),
          );
        }
      });

      window.addEventListener(PRESET_CHANGE_EVENT, (event) => {
        const detail = (
          event as CustomEvent<{ key?: unknown; preset?: { theme?: unknown } }>
        ).detail;
        const theme =
          typeof detail?.preset?.theme === "string"
            ? detail.preset.theme
            : resolveGradientThemeFromPresetId(
                typeof detail?.key === "string" ? detail.key : null,
              );
        syncPreviewGradientImages(theme);
      });

      document.addEventListener("astro:after-swap", () => {
        syncPreviewGradientImages();
      });
    </script>
  </body>
</html>

<style>
  ::-webkit-scrollbar {
    width: 10px;
  }

  /* Track */
  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  /* Handle */
  ::-webkit-scrollbar-thumb {
    background: #888;
  }

  /* Handle on hover */
  ::-webkit-scrollbar-thumb:hover {
    background: #555;
  }
</style>
