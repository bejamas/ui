---
import { Button } from "@bejamas/registry/ui/button";
import { Skeleton } from "@bejamas/registry/ui/skeleton";
import GitHubLink from "./GitHubLink.astro";

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
const githubUrl = "https://github.com/bejamas/ui";
---

<Button
  as="a"
  variant="outline"
  href={githubUrl}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["gap-1.5 w-16", className]}
  data-github-stars-button
  aria-label="View GitHub repository stars"
>
  <svg
    class="size-4"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path
      d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
    />
    <path d="M9 18c-4.51 2-5-2-7-2" />
  </svg>
  <GitHubLink server:defer>
    <span
      class="w-8.5 items-center flex justify-center text-center"
      data-github-stars-display
      slot="fallback"
    >
      <Skeleton class="w-8.5 h-5 rounded-sm" />
    </span>
  </GitHubLink>
</Button>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const button = script?.previousElementSibling;

    if (!(button instanceof HTMLElement) || !button.matches("[data-github-stars-button]")) {
      return;
    }

    const STORAGE_KEY = "bejamas:github-stars";
    const MAX_AGE = 1000 * 60 * 60 * 24;

    const readCache = () => {
      const read = (storage) => {
        try {
          const raw = storage.getItem(STORAGE_KEY);
          if (!raw) {
            return null;
          }

          const parsed = JSON.parse(raw);
          if (
            !parsed ||
            typeof parsed.value !== "string" ||
            !parsed.value ||
            typeof parsed.timestamp !== "number"
          ) {
            return null;
          }

          if (Date.now() - parsed.timestamp > MAX_AGE) {
            return null;
          }

          return parsed.value;
        } catch {
          return null;
        }
      };

      return read(localStorage) || read(sessionStorage);
    };

    const writeCache = (value) => {
      const payload = JSON.stringify({
        value,
        timestamp: Date.now(),
      });

      try {
        localStorage.setItem(STORAGE_KEY, payload);
      } catch {}

      try {
        sessionStorage.setItem(STORAGE_KEY, payload);
      } catch {}
    };

    const applyCachedValue = () => {
      const cachedValue = readCache();
      if (!cachedValue) {
        return;
      }

      const display = button.querySelector("[data-github-stars-display]");
      if (!(display instanceof HTMLElement)) {
        return;
      }

      display.textContent = cachedValue;
      display.dataset.githubStarsState = "cached";
    };

    const syncLiveValue = () => {
      const liveValue = button
        .querySelector("[data-github-stars-value]")
        ?.getAttribute("data-github-stars-value");

      if (!liveValue) {
        return false;
      }

      writeCache(liveValue);
      return true;
    };

    applyCachedValue();

    if (syncLiveValue()) {
      return;
    }

    const observer = new MutationObserver(() => {
      if (syncLiveValue()) {
        observer.disconnect();
      }
    });

    observer.observe(button, {
      childList: true,
      subtree: true,
    });
  })();
</script>
