---
import PlusIcon from "@lucide/astro/icons/plus";
import RefreshCwIcon from "@lucide/astro/icons/refresh-cw";
import SearchIcon from "@lucide/astro/icons/search";
import { Button } from "@bejamas/ui/components/button";
import CreateLockButton from "./CreateLockButton.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="flex items-center justify-between p-2.5 pl-4">
  <span class="flex items-center gap-2">
    <span class="text-sm font-medium tracking-[-0.01em] text-white/90" data-create-sidebar-title>
      {title}
    </span>
    <span hidden data-create-header-theme-lock>
      <CreateLockButton param="theme" class="opacity-100!" />
    </span>
  </span>
  <div class="flex items-center gap-0.5">
    <Button
      type="button"
      variant="ghost"
      size="icon"
      class="size-7! rounded-[8px]! border border-white/20 text-white/60 hover:text-white/90 hover:bg-white/[0.06]"
      data-create-header-navigate
      aria-label="Navigate"
    >
      <PlusIcon class="size-3.5" />
    </Button>
    <Button
      type="button"
      variant="ghost"
      size="icon"
      class="size-7! rounded-[8px]! border border-white/20 text-white/60 hover:text-white/90 hover:bg-white/[0.06]"
      data-create-header-shuffle
      aria-label="Shuffle"
    >
      <RefreshCwIcon class="size-3.5" />
    </Button>
    <Button
      type="button"
      variant="ghost"
      size="icon"
      class="size-7! rounded-[8px]! border border-white/20 text-white/60 hover:text-white/90 hover:bg-white/[0.06]"
      data-create-header-search
      aria-label="Search"
    >
      <SearchIcon class="size-3.5" />
    </Button>
  </div>
</div>
