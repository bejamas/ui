---
import CopyIcon from "@lucide/astro/icons/copy";
import MenuIcon from "@lucide/astro/icons/menu";
import RotateCcwIcon from "@lucide/astro/icons/rotate-ccw";
import ShuffleIcon from "@lucide/astro/icons/shuffle";
import { Button } from "@bejamas/ui/components/button";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuShortcut,
  DropdownMenuTrigger,
} from "@bejamas/ui/components/dropdown-menu";
import { Separator } from "@bejamas/ui/components/separator";
import { Switch } from "@bejamas/ui/components/switch";
import type { DesignSystemConfig } from "@bejamas/create-config/server";
import {
  CREATE_PICKER_LABELS,
  CREATE_PICKER_MARKERS,
  getCreatePickerOptions,
  getCreatePickerSelectedOption,
} from "@/utils/create-sidebar";
import CreatePicker from "./CreatePicker.astro";
import CreatePickerMarker from "./CreatePickerMarker.astro";
import CreateThemePanel from "./CreateThemePanel.astro";
import type { ThemeOverrides } from "@/utils/themes/create-theme";

interface Props {
  config: DesignSystemConfig;
  preset: string;
  themeRef?: string | null;
  themeOverrides?: ThemeOverrides | null;
}

const {
  config,
  preset,
  themeRef = null,
  themeOverrides = null,
} = Astro.props as Props;
const pickerOptions = getCreatePickerOptions(config);
const themeOption = getCreatePickerSelectedOption("theme", config);
const themeLabel = themeRef ? "Custom" : themeOption?.label ?? config.theme;
const themeSwatchColor =
  themeOverrides?.light?.primary ?? themeOption?.color ?? "oklch(0.72 0 0)";

const primaryPickers = [
  "style",
  "baseColor",
  "iconLibrary",
  "font",
  "radius",
  "menuColor",
  "menuAccent",
] as const;

const secondaryPickers = ["template"] as const;
---

<aside
  class="xl:sticky xl:top-[var(--create-page-inset)] xl:h-[var(--create-sidebar-height)]"
  data-create-customizer-stable
>
  <div
    class="create-customizer rounded-[26px] border border-white/8 bg-[#2a2927]/92 p-2.5 text-white shadow-[0_24px_70px_rgba(17,12,10,0.32)] backdrop-blur-xl xl:flex xl:h-full xl:flex-col"
  >
    <div
      class="create-customizer-toolbar flex items-center justify-between gap-2.5 rounded-[18px] border border-white/7 bg-white/[0.025] px-3 py-2"
    >
      <DropdownMenu data-create-main-menu class="block">
        <DropdownMenuTrigger asChild>
          <Button
            variant="ghost"
            class="!h-auto !rounded-[14px] !bg-transparent !px-0 !py-0 !text-white !shadow-none hover:!bg-transparent focus-visible:!ring-white/20"
          >
            <span
              class="flex items-center gap-2 text-sm font-medium tracking-[-0.01em]"
            >
              <MenuIcon class="size-4 text-white/70" />
              Menu
            </span>
          </Button>
        </DropdownMenuTrigger>
        <DropdownMenuContent
          data-create-main-menu-content
          side="right"
          align="start"
          sideOffset={10}
          class="!min-w-48 !rounded-[18px] !border-white/8 !bg-[#353331]/96 !p-1.25 !text-white !shadow-[0_18px_46px_rgba(0,0,0,0.3)] !ring-0 backdrop-blur-xl"
        >
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="shuffle"
          >
            <ShuffleIcon class="size-4 text-white/65" />
            Shuffle
            <DropdownMenuShortcut>R</DropdownMenuShortcut>
          </DropdownMenuItem>
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="reset"
          >
            <RotateCcwIcon class="size-4 text-white/65" />
            Reset to defaults
            <DropdownMenuShortcut>D</DropdownMenuShortcut>
          </DropdownMenuItem>
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="copy-command"
          >
            <CopyIcon class="size-4 text-white/65" />
            Copy command
            <DropdownMenuShortcut>C</DropdownMenuShortcut>
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>

      <div class="text-right">
        <p
          class="text-[11px] font-medium uppercase tracking-[0.16em] text-white/30"
        >
          Customizer
        </p>
        <p class="text-[13px] font-medium tracking-[-0.02em] text-white/72">
          Astro only
        </p>
      </div>
    </div>

    <form
      class="mt-2.5 xl:flex xl:min-h-0 xl:flex-1 xl:flex-col xl:overflow-hidden"
      data-create-form
    >
      <input type="hidden" name="theme" value={config.theme} data-create-theme-input-hidden />
      <input type="hidden" name="themeRef" value={themeRef ?? ""} data-create-theme-ref-input />

      <div
        class="space-y-2 overflow-y-auto pr-0.5 xl:min-h-0 xl:flex-1"
        data-create-form-main
      >
        {
          primaryPickers.map((picker) => (
            <CreatePicker
              name={picker}
              label={CREATE_PICKER_LABELS[picker]}
              value={config[picker]}
              options={pickerOptions[picker]}
              selectedOption={getCreatePickerSelectedOption(picker, config)}
              markerKind={CREATE_PICKER_MARKERS[picker]}
            />
          ))
        }

        <button
          type="button"
          class="flex w-full items-center justify-between rounded-[16px] border border-white/8 bg-white/[0.02] px-3 py-2.75 text-left text-white transition-colors hover:bg-white/[0.04]"
          data-create-theme-trigger
        >
          <span class="min-w-0 space-y-1">
            <span class="block text-[10px] font-medium uppercase tracking-[0.12em] text-white/38">
              Theme
            </span>
            <span
              class="block truncate text-[14px] font-medium tracking-[-0.01em] text-white/90"
              data-create-theme-current-label
            >
              {themeLabel}
            </span>
          </span>

          <span class="ml-2.5 flex shrink-0 items-center gap-1.5 text-white/65">
            <span class="inline-flex items-center justify-center" data-create-theme-current-marker>
              <CreatePickerMarker
                kind="swatch"
                value={config.theme}
                label={themeLabel}
                color={themeSwatchColor}
              />
            </span>
          </span>
        </button>

        <Separator class="!my-2.5 !bg-white/8" />

        {
          secondaryPickers.map((picker) => (
            <CreatePicker
              name={picker}
              label={CREATE_PICKER_LABELS[picker]}
              value={config[picker]}
              options={pickerOptions[picker]}
              selectedOption={getCreatePickerSelectedOption(picker, config)}
              markerKind={CREATE_PICKER_MARKERS[picker]}
            />
          ))
        }

        <label
          class="flex items-center justify-between rounded-[16px] border border-white/8 bg-white/[0.02] px-3 py-2.5 text-white"
        >
          <span class="space-y-1">
            <span
              class="block text-[10px] font-medium uppercase tracking-[0.12em] text-white/38"
              >Direction</span
            >
            <span
              class="block text-[14px] font-medium tracking-[-0.01em] text-white/90"
              >RTL output</span
            >
          </span>
          <Switch
            name="rtl"
            checked={config.rtl}
            class="!bg-white/15 peer-checked:!bg-white"
            data-create-rtl
          />
        </label>
      </div>

      <CreateThemePanel
        config={config}
        themeRef={themeRef}
        themeOverrides={themeOverrides}
      />
    </form>

    <Separator class="!my-2.5 !bg-white/8" />

    <div class="space-y-1.5 xl:shrink-0">
      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-copy-preset
      >
        <span data-preset-code>{`--preset ${preset}`}</span>
      </button>

      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-copy-command
      >
        <span data-command>Copy command</span>
      </button>

      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-randomize
      >
        <span>Shuffle</span>
      </button>
    </div>
  </div>
</aside>
