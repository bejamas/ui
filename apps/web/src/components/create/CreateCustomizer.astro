---
import CopyIcon from "@lucide/astro/icons/copy";
import MenuIcon from "@lucide/astro/icons/menu";
import RotateCcwIcon from "@lucide/astro/icons/rotate-ccw";
import ShuffleIcon from "@lucide/astro/icons/shuffle";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuShortcut,
  DropdownMenuTrigger,
} from "@bejamas/ui/components/dropdown-menu";
import { Separator } from "@bejamas/ui/components/separator";
import { Switch } from "@bejamas/ui/components/switch";
import type { DesignSystemConfig } from "@bejamas/create-config/server";
import {
  CREATE_PICKER_LABELS,
  CREATE_PICKER_MARKERS,
  getCreatePickerOptions,
  getCreatePickerSelectedOption,
} from "@/utils/create-sidebar";
import CreatePicker from "./CreatePicker.astro";

interface Props {
  config: DesignSystemConfig;
  preset: string;
}

const { config, preset } = Astro.props as Props;
const pickerOptions = getCreatePickerOptions(config);

const primaryPickers = [
  "style",
  "baseColor",
  "theme",
  "iconLibrary",
  "font",
  "radius",
  "menuColor",
  "menuAccent",
] as const;

const secondaryPickers = ["template"] as const;
---

<aside class="xl:sticky xl:top-6" data-create-customizer-stable>
  <div class="create-customizer rounded-[26px] border border-white/8 bg-[#2a2927]/92 p-2.5 text-white shadow-[0_24px_70px_rgba(17,12,10,0.32)] backdrop-blur-xl">
    <div class="create-customizer-toolbar flex items-center justify-between gap-2.5 rounded-[18px] border border-white/7 bg-white/[0.025] px-3 py-2">
      <DropdownMenu data-create-main-menu class="block">
        <DropdownMenuTrigger
          variant="ghost"
          type="button"
          class="!h-auto !rounded-[14px] !bg-transparent !px-0 !py-0 !text-white !shadow-none hover:!bg-transparent focus-visible:!ring-white/20"
        >
          <span class="flex items-center gap-2 text-sm font-medium tracking-[-0.01em]">
            <MenuIcon class="size-4 text-white/70" />
            Menu
          </span>
        </DropdownMenuTrigger>
        <DropdownMenuContent
          data-create-main-menu-content
          side="right"
          align="start"
          sideOffset={10}
          class="!min-w-48 !rounded-[18px] !border-white/8 !bg-[#353331]/96 !p-1.25 !text-white !shadow-[0_18px_46px_rgba(0,0,0,0.3)] !ring-0 backdrop-blur-xl"
        >
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="shuffle"
          >
            <ShuffleIcon class="size-4 text-white/65" />
            Shuffle
            <DropdownMenuShortcut>R</DropdownMenuShortcut>
          </DropdownMenuItem>
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="reset"
          >
            <RotateCcwIcon class="size-4 text-white/65" />
            Reset to defaults
            <DropdownMenuShortcut>D</DropdownMenuShortcut>
          </DropdownMenuItem>
          <DropdownMenuItem
            class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
            data-value="copy-command"
          >
            <CopyIcon class="size-4 text-white/65" />
            Copy command
            <DropdownMenuShortcut>C</DropdownMenuShortcut>
          </DropdownMenuItem>
        </DropdownMenuContent>
      </DropdownMenu>

      <div class="text-right">
        <p class="text-[11px] font-medium uppercase tracking-[0.16em] text-white/30">Customizer</p>
        <p class="text-[13px] font-medium tracking-[-0.02em] text-white/72">Astro only</p>
      </div>
    </div>

    <form class="mt-2.5 space-y-2" data-create-form>
      <div class="max-h-[min(58vh,640px)] space-y-2 overflow-y-auto pr-0.5">
        {
          primaryPickers.map((picker) => (
            <CreatePicker
              name={picker}
              label={CREATE_PICKER_LABELS[picker]}
              value={config[picker]}
              options={pickerOptions[picker]}
              selectedOption={getCreatePickerSelectedOption(picker, config)}
              markerKind={CREATE_PICKER_MARKERS[picker]}
            />
          ))
        }

        <Separator class="!my-2.5 !bg-white/8" />

        {
          secondaryPickers.map((picker) => (
            <CreatePicker
              name={picker}
              label={CREATE_PICKER_LABELS[picker]}
              value={config[picker]}
              options={pickerOptions[picker]}
              selectedOption={getCreatePickerSelectedOption(picker, config)}
              markerKind={CREATE_PICKER_MARKERS[picker]}
            />
          ))
        }

        <label class="flex items-center justify-between rounded-[16px] border border-white/8 bg-white/[0.02] px-3 py-2.5 text-white">
          <span class="space-y-1">
            <span class="block text-[10px] font-medium uppercase tracking-[0.12em] text-white/38">Direction</span>
            <span class="block text-[14px] font-medium tracking-[-0.01em] text-white/90">RTL output</span>
          </span>
          <Switch
            name="rtl"
            checked={config.rtl}
            class="!bg-white/15 peer-checked:!bg-white"
            data-create-rtl
          />
        </label>
      </div>
    </form>

    <Separator class="!my-2.5 !bg-white/8" />

    <div class="space-y-1.5">
      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-copy-preset
      >
        <span data-preset-code>{`--preset ${preset}`}</span>
      </button>

      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-copy-command
      >
        <span data-command>Copy command</span>
      </button>

      <button
        type="button"
        class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-randomize
      >
        <span>Shuffle</span>
      </button>
    </div>
  </div>
</aside>
