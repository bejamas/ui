---
import FolderPlusIcon from "@lucide/astro/icons/folder-plus";
import MenuIcon from "@lucide/astro/icons/menu";
import RotateCcwIcon from "@lucide/astro/icons/rotate-ccw";
import ShuffleIcon from "@lucide/astro/icons/shuffle";
import { Button } from "@bejamas/ui/components/button";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuShortcut,
  DropdownMenuTrigger,
} from "@bejamas/ui/components/dropdown-menu";
import { Separator } from "@bejamas/ui/components/separator";
import { Switch } from "@bejamas/ui/components/switch";
import type { DesignSystemConfig } from "@bejamas/create-config/server";
import {
  CREATE_PICKER_LABELS,
  CREATE_PICKER_MARKERS,
  getCreatePickerOptions,
  isCreatePickerDisabled,
  getCreatePickerSelectedOption,
} from "@/utils/create-sidebar";
import CreateLockButton from "./CreateLockButton.astro";
import CreatePicker from "./CreatePicker.astro";
import CreatePickerMarker from "./CreatePickerMarker.astro";
import CreateNavigateDialog from "./CreateNavigateDialog.astro";
import CreateProjectDialog from "./CreateProjectDialog.astro";
import CreateThemePanel from "./CreateThemePanel.astro";
import {
  getCreateThemeSeedOption,
  type ThemeOverrides,
} from "@/utils/themes/create-theme";

interface Props {
  config: DesignSystemConfig;
  preset: string;
  themeRef?: string | null;
  themeOverrides?: ThemeOverrides | null;
}

const {
  config,
  preset,
  themeRef = null,
  themeOverrides = null,
} = Astro.props as Props;
const pickerOptions = getCreatePickerOptions(config);
const themeOption = getCreateThemeSeedOption(config.baseColor, config.theme);
const themeLabel = themeRef ? "Custom" : (themeOption?.label ?? config.theme);
const themeSwatchColor =
  themeOverrides?.light?.primary ?? themeOption?.color ?? "oklch(0.72 0 0)";

const primaryPickers = [
  "style",
  "baseColor",
  "iconLibrary",
  "font",
  "radius",
  "menuColor",
  "menuAccent",
] as const;
---

<aside
  class="xl:sticky xl:top-[var(--create-page-inset)] xl:h-[var(--create-sidebar-height)] dark"
  data-create-customizer-stable
>
  <div
    class="create-customizer rounded-[22px] border bg-secondary/90 text-white shadow-[0_24px_70px_rgba(17,12,10,0.32)] backdrop-blur-xl xl:flex xl:h-full xl:flex-col"
  >
    <DropdownMenu data-create-main-menu class="flex items-center w-full p-2.5">
      <DropdownMenuTrigger asChild class="w-full">
        <Button
          variant="outline"
          class="create-customizer-toolbar w-full flex items-center justify-between gap-2.5 rounded-[12px]! px-3 py-2"
        >
          <span
            class="flex items-center gap-2 text-sm font-medium tracking-[-0.01em]"
          >
            <MenuIcon class="size-4 text-white/70" />
            Menu
          </span>
        </Button>
      </DropdownMenuTrigger>
      <DropdownMenuContent
        data-create-main-menu-content
        side="right"
        align="start"
        sideOffset={20}
        class="!min-w-48 !rounded-[18px] !border-white/8 !bg-[#353331]/96 !p-1.25 !text-white !shadow-[0_18px_46px_rgba(0,0,0,0.3)] !ring-0 backdrop-blur-xl"
      >
        <DropdownMenuItem
          class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
          data-value="navigate"
        >
          <MenuIcon class="size-4 text-white/65" />
          Navigate...
          <DropdownMenuShortcut>⌘P</DropdownMenuShortcut>
        </DropdownMenuItem>
        <DropdownMenuItem
          class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
          data-value="shuffle"
        >
          <ShuffleIcon class="size-4 text-white/65" />
          Shuffle
          <DropdownMenuShortcut>R</DropdownMenuShortcut>
        </DropdownMenuItem>
        <DropdownMenuItem
          class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
          data-value="reset"
        >
          <RotateCcwIcon class="size-4 text-white/65" />
          Reset to defaults
          <DropdownMenuShortcut>D</DropdownMenuShortcut>
        </DropdownMenuItem>
        <DropdownMenuItem
          class="!rounded-[12px] !px-3 !py-2 !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
          data-value="create-project"
        >
          <FolderPlusIcon class="size-4 text-white/65" />
          Create project
        </DropdownMenuItem>
      </DropdownMenuContent>
    </DropdownMenu>

    <Separator class="!bg-white/8" />

    <form
      class="xl:flex xl:min-h-0 xl:flex-1 xl:flex-col xl:overflow-hidden"
      data-create-form
    >
      <input
        type="hidden"
        name="theme"
        value={config.theme}
        data-create-theme-input-hidden
      />
      <input
        type="hidden"
        name="themeRef"
        value={themeRef ?? ""}
        data-create-theme-ref-input
      />

      <div
        class="overflow-y-auto xl:min-h-0 xl:flex-1 [scrollbar-width:none] gap-y-1 will-change-[opacity,filter] transition-[opacity,filter] duration-80 ease-out motion-reduce:transition-none data-[panel-state=entering]:opacity-0 data-[panel-state=entering]:blur-sm data-[panel-state=entering]:pointer-events-none data-[panel-state=exiting]:opacity-0 data-[panel-state=exiting]:blur-sm data-[panel-state=exiting]:pointer-events-none data-[panel-state=inactive]:opacity-0 data-[panel-state=inactive]:blur-sm data-[panel-state=inactive]:pointer-events-none"
        data-create-form-main
        data-panel-state="active"
      >
        <div class="p-2.5 gap-2 flex flex-col">
          {
            primaryPickers.map((picker) => (
              <CreatePicker
                name={picker}
                label={CREATE_PICKER_LABELS[picker]}
                value={config[picker]}
                options={pickerOptions[picker]}
                selectedOption={getCreatePickerSelectedOption(picker, config)}
                markerKind={CREATE_PICKER_MARKERS[picker]}
                lockable
                lockParam={picker}
                disabled={isCreatePickerDisabled(picker, config)}
              />
            ))
          }

          <div class="group/picker relative">
            <Button
              type="button"
              variant="outline"
              class="create-picker-trigger bg-transparent! hover:bg-muted! border-border/70! flex w-full justify-between text-left h-auto! rounded-[12px]! px-3! py-2!"
              data-create-theme-trigger
            >
              <span class="min-w-0">
                <span
                  class="block text-[8px] font-medium uppercase tracking-[0.12em] text-white/38"
                >
                  Theme
                </span>
                <span
                  class="block truncate text-sm font-medium tracking-[-0.01em] text-white/90"
                  data-create-theme-current-label
                >
                  {themeLabel}
                </span>
              </span>

              <span
                class="ml-2.5 flex shrink-0 items-center gap-1.5 text-white/65"
              >
                <span
                  class="inline-flex items-center justify-center"
                  data-create-theme-current-marker
                >
                  <CreatePickerMarker
                    kind="swatch"
                    value={config.theme}
                    label={themeLabel}
                    color={themeSwatchColor}
                  />
                </span>
              </span>
            </Button>

            <CreateLockButton
              param="theme"
              class="absolute top-1/2 right-8 -translate-y-1/2"
            />
          </div>
        </div>

        <Separator class="!bg-white/8" />

        <div class="p-2.5 flex flex-col gap-2">
          <label
            class="border border-border flex w-full justify-between text-left h-auto! rounded-[12px]! px-3! py-2!"
          >
            <span>
              <span
                class="block text-[8px] font-medium uppercase tracking-[0.12em] text-white/38"
                >Direction</span
              >
              <span
                class="block text-[14px] font-medium tracking-[-0.01em] text-white/90"
                >RTL</span
              >
            </span>
            <Switch
              name="rtl"
              checked={config.rtl}
              class="!bg-white/15 peer-checked:!bg-white"
              data-create-rtl
            />
          </label>

          <div class:list={[!config.rtl && "hidden"]} data-create-rtl-language>
            <CreatePicker
              name="rtlLanguage"
              label={CREATE_PICKER_LABELS.rtlLanguage}
              value={config.rtlLanguage}
              options={pickerOptions.rtlLanguage}
              selectedOption={getCreatePickerSelectedOption(
                "rtlLanguage",
                config,
              )}
              markerKind={CREATE_PICKER_MARKERS.rtlLanguage}
            />
          </div>
        </div>
      </div>

      <CreateThemePanel
        config={config}
        themeRef={themeRef}
        themeOverrides={themeOverrides}
      />
    </form>

    <Separator class="!bg-white/8" />

    <div class="create-customizer-actions p-2.5 xl:shrink-0">
      <CreateNavigateDialog />

      <button
        type="button"
        class="create-customizer-action hidden w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-copy-preset
      >
        <span data-preset-code>{`--preset ${preset}`}</span>
      </button>

      <div class="grid grid-cols-2 gap-2">
        <CreateProjectDialog
          config={config}
          preset={preset}
          themeRef={themeRef}
        />

        <Button
          type="button"
          variant="outline"
          class="create-customizer-action flex w-full items-center justify-center rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[13px] font-medium text-white/92 transition-colors hover:bg-white/[0.05]"
          data-create-randomize
        >
          <span>Shuffle</span>
        </Button>
      </div>
    </div>
  </div>
</aside>
