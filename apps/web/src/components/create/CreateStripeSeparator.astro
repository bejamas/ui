---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class:list={["create-stripe-separator h-2 w-full", className]}
  aria-hidden="true"
/>

<style>
  .create-stripe-separator {
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 3px,
      rgba(255, 255, 255, 0.05) 3px,
      rgba(255, 255, 255, 0.05) 4px
    );
  }
</style>
