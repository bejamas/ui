---
import CheckIcon from "@lucide/astro/icons/check";
import ChevronDownIcon from "@lucide/astro/icons/chevron-down";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuTrigger,
} from "@bejamas/ui/components/dropdown-menu";
import type {
  CreatePickerMarkerKind,
  CreatePickerOption,
  CreatePickerName,
} from "@/utils/create-sidebar";
import CreatePickerMarker from "./CreatePickerMarker.astro";

interface Props {
  name: CreatePickerName;
  label: string;
  value: string;
  options: CreatePickerOption[];
  selectedOption?: CreatePickerOption;
  markerKind: CreatePickerMarkerKind;
}

const {
  name,
  label,
  value,
  options,
  selectedOption: providedSelectedOption,
  markerKind,
} = Astro.props as Props;
const selectedOption =
  providedSelectedOption ??
  options.find((option) => option.value === value) ?? options[0];
---

<DropdownMenu data-create-picker={name} class="block w-full">
  <input type="hidden" name={name} value={selectedOption?.value ?? value} data-create-input />

  <DropdownMenuTrigger
    variant="ghost"
    type="button"
    class="create-picker-trigger !h-auto !w-full !justify-between !rounded-[16px] !border !border-white/8 !bg-white/[0.02] !px-3 !py-2.75 !text-left !text-white !shadow-none hover:!bg-white/[0.04] focus-visible:!ring-white/20 data-[state=open]:!bg-white/[0.05]"
    data-create-picker-trigger
  >
    <span class="min-w-0 space-y-1">
      <span class="block text-[10px] font-medium uppercase tracking-[0.12em] text-white/38">{label}</span>
      <span
        class="block truncate text-[14px] font-medium tracking-[-0.01em] text-white/90"
        data-create-picker-current-label
      >
        {selectedOption?.label ?? value}
      </span>
    </span>

    <span class="ml-2.5 flex shrink-0 items-center gap-1.5 text-white/65">
      <span class="inline-flex items-center justify-center" data-create-picker-current-marker>
        {
          selectedOption && (
            <CreatePickerMarker
              kind={markerKind}
              value={selectedOption.markerValue ?? selectedOption.value}
              label={selectedOption.label}
              color={selectedOption.color}
              family={selectedOption.family}
            />
          )
        }
      </span>
      <ChevronDownIcon class="size-4 text-white/35" aria-hidden="true" />
    </span>
  </DropdownMenuTrigger>

  <DropdownMenuContent
    data-create-picker-content={name}
    side="right"
    align="start"
    sideOffset={10}
    class="create-picker-content !min-w-[10.5rem] !rounded-[18px] !border-white/8 !bg-[#353331]/96 !p-1.25 !text-white !shadow-[0_20px_50px_rgba(0,0,0,0.32)] !ring-0 backdrop-blur-xl"
  >
    <div data-create-picker-items>
      {
        options.map((option) => {
          const isSelected = option.value === selectedOption?.value;

          return (
            <DropdownMenuItem
              class="create-picker-item !gap-2.5 !rounded-[12px] !px-3 !py-2 !text-[14px] !font-medium !text-white/86 data-[highlighted]:!bg-white/[0.06] data-[highlighted]:!text-white/92"
              data-create-picker-item
              data-value={option.value}
              data-selected={isSelected ? "" : undefined}
            >
              <span class="truncate" data-create-picker-item-label>{option.label}</span>
              <span class="ml-auto flex shrink-0 items-center gap-2">
                <span data-create-picker-item-marker>
                    <CreatePickerMarker
                      kind={markerKind}
                      value={option.markerValue ?? option.value}
                      label={option.label}
                      color={option.color}
                      family={option.family}
                  />
                </span>
                <CheckIcon
                  class:list={[
                    "size-4 text-white/78 transition-opacity",
                    isSelected ? "opacity-100" : "opacity-0",
                  ]}
                  data-create-picker-item-check
                  aria-hidden="true"
                />
              </span>
            </DropdownMenuItem>
          );
        })
      }
    </div>
  </DropdownMenuContent>
</DropdownMenu>
