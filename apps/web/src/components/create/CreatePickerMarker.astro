---
import { cn } from "@bejamas/ui/lib/utils";
import { getRadiusValue } from "@bejamas/create-config/browser";
import type { CreatePickerMarkerKind } from "@/utils/create-sidebar";

interface Props {
  kind: CreatePickerMarkerKind;
  value: string;
  label: string;
  color?: string;
  family?: string;
  class?: string;
}

const {
  kind,
  value,
  label,
  color,
  family,
  class: className = "",
} = Astro.props as Props;

const iconLibraryAbbreviations: Record<string, string> = {
  lucide: "Lu",
  hugeicons: "Hu",
  tabler: "Tb",
  phosphor: "Ph",
  remixicon: "Ri",
};

const styleInitial = label.slice(0, 1).toUpperCase();
const STYLE_ICON_PATHS: Record<string, { d: string; join?: "round" }> = {
  juno: {
    d: "M8 2H16L22 8V16L16 22H8L2 16V8L8 2Z",
  },
  vega: {
    d: "M2.5 12C2.5 7.52166 2.5 5.28249 3.89124 3.89124C5.28249 2.5 7.52166 2.5 12 2.5C16.4783 2.5 18.7175 2.5 20.1088 3.89124C21.5 5.28249 21.5 7.52166 21.5 12C21.5 16.4783 21.5 18.7175 20.1088 20.1088C18.7175 21.5 16.4783 21.5 12 21.5C7.52166 21.5 5.28249 21.5 3.89124 20.1088C2.5 18.7175 2.5 16.4783 2.5 12Z",
  },
  nova: {
    d: "M2 12C2 9.19974 2 7.79961 2.54497 6.73005C3.02433 5.78924 3.78924 5.02433 4.73005 4.54497C5.79961 4 7.19974 4 10 4H14C16.8003 4 18.2004 4 19.27 4.54497C20.2108 5.02433 20.9757 5.78924 21.455 6.73005C22 7.79961 22 9.19974 22 12C22 14.8003 22 16.2004 21.455 17.27C20.9757 18.2108 20.2108 18.9757 19.27 19.455C18.2004 20 16.8003 20 14 20H10C7.19974 20 5.79961 20 4.73005 19.455C3.78924 18.9757 3.02433 18.2108 2.54497 17.27C2 16.2004 2 14.8003 2 12Z",
    join: "round",
  },
  maia: {
    d: "M2 12A10 10 0 1 1 22 12A10 10 0 1 1 2 12Z",
    join: "round",
  },
  lyra: {
    d: "M7.84308 3.80211C9.8718 2.6007 10.8862 2 12 2C13.1138 2 14.1282 2.6007 16.1569 3.80211L16.8431 4.20846C18.8718 5.40987 19.8862 6.01057 20.4431 7C21 7.98943 21 9.19084 21 11.5937V12.4063C21 14.8092 21 16.0106 20.4431 17C19.8862 17.9894 18.8718 18.5901 16.8431 19.7915L16.1569 20.1979C14.1282 21.3993 13.1138 22 12 22C10.8862 22 9.8718 21.3993 7.84308 20.1979L7.15692 19.7915C5.1282 18.5901 4.11384 17.9894 3.55692 17C3 16.0106 3 14.8092 3 12.4063V11.5937C3 9.19084 3 7.98943 3.55692 7C4.11384 6.01057 5.1282 5.40987 7.15692 4.20846L7.84308 3.80211Z",
  },
  mira: {
    d: "M5.92089 5.92089C8.15836 3.68342 9.2771 2.56468 10.5857 2.19562C11.5105 1.93479 12.4895 1.93479 13.4143 2.19562C14.7229 2.56468 15.8416 3.68342 18.0791 5.92089C20.3166 8.15836 21.4353 9.2771 21.8044 10.5857C22.0652 11.5105 22.0652 12.4895 21.8044 13.4143C21.4353 14.7229 20.3166 15.8416 18.0791 18.0791C15.8416 20.3166 14.7229 21.4353 13.4143 21.8044C12.4895 22.0652 11.5105 22.0652 10.5857 21.8044C9.2771 21.4353 8.15836 20.3166 5.92089 18.0791C3.68342 15.8416 2.56468 14.7229 2.19562 13.4143C1.93479 12.4895 1.93479 11.5105 2.19562 10.5857C2.56468 9.2771 3.68342 8.15836 5.92089 5.92089Z",
    join: "round",
  },
  luma: {
    d: "M2 12C2 8.134 5.134 5 9 5H15C18.866 5 22 8.134 22 12C22 15.866 18.866 19 15 19H9C5.134 19 2 15.866 2 12Z",
    join: "round",
  },
};
const styleIcon = STYLE_ICON_PATHS[value];
const iconLibraryLabel = iconLibraryAbbreviations[value] ?? label.slice(0, 2);
const languageLabel = value.slice(0, 2).toUpperCase();
const radius = getRadiusValue(value as Parameters<typeof getRadiusValue>[0]);
const isMenuInverted =
  value === "inverted" || value === "inverted-translucent";
const isMenuTranslucent =
  value === "default-translucent" || value === "inverted-translucent";
---

{
  kind === "swatch" && (
    <span
      class={cn(
        "inline-flex size-4 shrink-0 rounded-full border border-white/20 shadow-[inset_0_1px_0_rgba(255,255,255,0.14)]",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
      style={color ? `background:${color};` : undefined}
    />
  )
}

{
  kind === "style" &&
    (styleIcon
      ? (
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin={styleIcon.join}
            class={cn("size-4 shrink-0 text-white/80", className)}
            data-create-picker-marker
            aria-hidden="true"
          >
            <path d={styleIcon.d} />
          </svg>
        )
      : (
          <span
            class={cn(
              "inline-flex size-4 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/5 text-[9px] font-semibold uppercase text-white/80",
              className,
            )}
            data-create-picker-marker
            aria-hidden="true"
          >
            {styleInitial}
          </span>
        ))
}

{
  kind === "icon-library" && (
    <span
      class={cn(
        "inline-flex min-w-4 shrink-0 items-center justify-center text-[10px] font-semibold tracking-[0.08em] text-white/80 uppercase",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
    >
      {iconLibraryLabel}
    </span>
  )
}

{
  kind === "font" && (
    <span
      class={cn(
        "inline-flex min-w-5 shrink-0 items-center justify-center text-sm font-medium text-white/85",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
      style={family ? `font-family:${family};` : undefined}
    >
      Aa
    </span>
  )
}

{
  kind === "radius" && (
    <span
      class={cn(
        "inline-flex size-4 shrink-0 items-center justify-center rounded-[4px] border border-white/18 bg-white/4",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
      style={`border-radius:${radius};`}
    >
      <span class="size-1.5 rounded-full bg-white/55" />
    </span>
  )
}

{
  kind === "menu-color" && (
    <span
      class={cn(
        "relative inline-flex h-4 w-5 shrink-0 overflow-hidden rounded-[6px] border border-white/18 bg-white/5",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
    >
      <span
        class:list={[
          "block h-full w-1/2",
          isMenuInverted ? "bg-neutral-950" : "bg-neutral-100",
        ]}
      />
      <span
        class:list={[
          "block h-full w-1/2",
          isMenuInverted ? "bg-neutral-100" : "bg-neutral-950",
        ]}
      />
      {
        isMenuTranslucent && (
          <>
            <span class="absolute inset-x-0 top-0 h-[1px] bg-white/30" />
            <span class="absolute inset-y-0 left-1/2 w-[1px] -translate-x-1/2 bg-white/15" />
          </>
        )
      }
    </span>
  )
}

{
  kind === "menu-accent" && (
    <span
      class={cn(
        "inline-flex h-4 w-5 shrink-0 items-center rounded-full border border-white/18 px-0.5",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
    >
      <span
        class:list={[
          "block h-2.5 rounded-full transition-all",
          value === "bold" ? "w-full bg-white/90" : "w-2 bg-white/55",
        ]}
      />
    </span>
  )
}

{
  kind === "template" && (
    <span
      class={cn(
        "inline-flex h-4 w-5 shrink-0 items-center justify-between rounded-[6px] border border-white/18 bg-white/4 p-0.5",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
    >
      <span class="h-full w-[34%] rounded-[4px] bg-white/55" />
      <span class="flex h-full w-[56%] flex-col justify-between">
        <span class="h-[38%] rounded-[3px] bg-white/28" />
        <span class="h-[38%] rounded-[3px] bg-white/18" />
      </span>
    </span>
  )
}

{
  kind === "language" && (
    <span
      class={cn(
        "inline-flex min-w-5 shrink-0 items-center justify-center rounded-full border border-white/18 bg-white/4 px-1.5 text-[10px] font-semibold uppercase tracking-[0.08em] text-white/80",
        className,
      )}
      data-create-picker-marker
      aria-hidden="true"
    >
      {languageLabel}
    </span>
  )
}
