---
import ArrowLeftIcon from "@lucide/astro/icons/arrow-left";
import DownloadIcon from "@lucide/astro/icons/download";
import CreateLockButton from "./CreateLockButton.astro";
import { resolveDesignSystemTheme } from "@/utils/themes/design-system-adapter";
import {
  CREATE_THEME_TOKEN_SECTIONS,
  formatThemeTokenLabel,
  getCreateThemeSeedGroups,
  type ThemeOverrides,
} from "@/utils/themes/create-theme";
import ColorInput from "@/components/theme-editor/ColorInput.astro";
import ImportDialog from "@/components/theme-editor/ImportDialog.astro";
import type { DesignSystemConfig } from "@bejamas/create-config/server";

interface Props {
  config: DesignSystemConfig;
  themeRef?: string | null;
  themeOverrides?: ThemeOverrides | null;
}

const { config, themeRef = null, themeOverrides = null } = Astro.props as Props;
const themeSeedGroups = getCreateThemeSeedGroups(config.baseColor);
const resolvedTheme = resolveDesignSystemTheme(config, themeOverrides).styles;
---

<section
  hidden
  class="space-y-3.5 xl:min-h-0 p-2.5 xl:flex xl:flex-1 xl:flex-col xl:overflow-hidden will-change-[opacity,filter] transition-[opacity,filter] duration-100 ease-out motion-reduce:transition-none data-[panel-state=entering]:opacity-0 data-[panel-state=entering]:blur-sm data-[panel-state=entering]:pointer-events-none data-[panel-state=exiting]:opacity-0 data-[panel-state=exiting]:blur-sm data-[panel-state=exiting]:pointer-events-none data-[panel-state=inactive]:opacity-0 data-[panel-state=inactive]:blur-sm data-[panel-state=inactive]:pointer-events-none"
  data-create-theme-panel
  data-panel-state="inactive"
>
  <div class="flex items-center justify-between gap-2">
    <div class="group/picker relative">
      <button
        type="button"
        class="flex items-center gap-2 rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 pr-9 text-sm font-medium tracking-[-0.01em] text-white/92 transition-colors hover:bg-white/[0.05]"
        data-create-theme-back
      >
        <ArrowLeftIcon class="size-4 text-white/70" />
        Theme
      </button>
      <CreateLockButton
        param="theme"
        class="absolute top-1/2 right-3 -translate-y-1/2"
      />
    </div>

    <button
      type="button"
      class="flex items-center gap-2 rounded-[14px] border border-white/8 bg-white/[0.02] px-3 py-2 text-[12px] font-medium text-white/82 transition-colors hover:bg-white/[0.05]"
      data-create-theme-import
    >
      <DownloadIcon class="size-4 text-white/65" />
      Import
    </button>
  </div>

  <div class="overflow-auto gap-3 flex flex-col">
    <p
      class="min-h-5 text-[11px] leading-4 text-white/48 mb-3 text-balance"
      data-create-theme-status
    >
      {
        themeRef
          ? "Custom theme loaded. Edit tokens or import CSS to update it."
          : "Pick a seed theme, then adjust tokens in light and dark modes."
      }
    </p>

    <div class="space-y-2" data-create-theme-seeds>
      {
        themeSeedGroups.map((group) => (
          <section class="space-y-2" data-create-theme-group={group.group}>
            <header class="px-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-white/38">
              {group.label}
            </header>
            <div class="grid grid-cols-2 gap-2">
              {group.options.map((option) => (
                <button
                  type="button"
                  class:list={[
                    "flex items-center gap-2 rounded-[12px] border px-2.5 py-2 text-left transition-colors",
                    option.value === config.theme
                      ? "border-white/16 bg-white/[0.08] text-white"
                      : "border-white/0 bg-white/[0.02] text-white/78 hover:bg-white/[0.05]",
                  ]}
                  data-create-theme-option
                  data-value={option.value}
                  data-selected={option.value === config.theme ? "" : undefined}
                >
                  <span
                    class="inline-flex size-4 shrink-0 rounded-full border border-white/18 shadow-[inset_0_1px_0_rgba(255,255,255,0.14)]"
                    style={`background:${option.color};`}
                  />
                  <span class="truncate text-[13px] font-medium tracking-[-0.01em]">
                    {option.label}
                  </span>
                </button>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    <div
      class="flex items-center gap-1 rounded-[14px] border border-white/8 bg-white/[0.02] p-1"
    >
      {
        (["light", "dark"] as const).map((mode, index) => (
          <button
            type="button"
            class:list={[
              "flex-1 rounded-[10px] px-3 py-1.5 text-[12px] font-medium tracking-[-0.01em] transition-colors",
              index === 0
                ? "bg-white/[0.09] text-white"
                : "text-white/62 hover:text-white/86",
            ]}
            data-create-theme-tab
            data-value={mode}
            data-selected={index === 0 ? "" : undefined}
          >
            {mode === "light" ? "Light" : "Dark"}
          </button>
        ))
      }
    </div>

    <div class="xl:flex-1">
      {
        (["light", "dark"] as const).map((mode, index) => (
          <div
            class:list={["space-y-4", index > 0 && "hidden"]}
            data-create-theme-mode-panel
            data-mode={mode}
          >
            {CREATE_THEME_TOKEN_SECTIONS.map((section) => (
              <section class="space-y-2 rounded-[18px] border border-white/8 bg-white/[0.02] p-3">
                <header class="flex items-center justify-between gap-2">
                  <h3 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-white/38">
                    {section.title}
                  </h3>
                  <span class="text-[10px] text-white/28">
                    {section.tokens.length} tokens
                  </span>
                </header>

                <div class="grid grid-cols-2 gap-2">
                  {section.tokens.map((token) => (
                    <ColorInput
                      token={token}
                      label={formatThemeTokenLabel(token)}
                      value={resolvedTheme[mode][token] ?? ""}
                      class="rounded-[12px] border border-white/8 bg-white/[0.03] p-2"
                      data-create-theme-input
                      data-create-theme-mode={mode}
                    />
                  ))}
                </div>
              </section>
            ))}
          </div>
        ))
      }
    </div>

    <ImportDialog />
  </div>
</section>
