---
import { cn } from "@bejamas/ui/lib/utils";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  class?: string;
}

const { class: className = "", ...rest } = Astro.props as Props;
---

<div
  hidden
  data-slot="dialog-overlay"
  class={cn(
    "cn-dialog-overlay",
    "data-open:animate-in data-closed:animate-out data-closed:fade-out-0 data-open:fade-in-0 fixed inset-0 bg-black/10 duration-100 supports-backdrop-filter:backdrop-blur-xs",
    className,
  )}
  {...rest}
>
  <slot />
</div>
