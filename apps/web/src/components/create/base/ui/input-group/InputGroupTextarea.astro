---
import type { HTMLAttributes } from "astro/types";
import { cn } from "@bejamas/ui/lib/utils";
import { Textarea } from "../textarea";

interface Props extends HTMLAttributes<"textarea"> {
  class?: string;
}

const { class: className = "", ...rest } = Astro.props as Props;

const textareaClasses =
  "flex-1 min-w-0 resize-none rounded-none border-0 bg-transparent text-base shadow-none focus-visible:ring-0 dark:bg-transparent dark:disabled:bg-transparent group-data-[size=sm]/input-group:px-2.5 group-data-[size=sm]/input-group:py-2 group-data-[size=sm]/input-group:md:text-xs group-data-[size=default]/input-group:px-3 group-data-[size=default]/input-group:py-2.5 group-data-[size=default]/input-group:md:text-sm group-data-[size=lg]/input-group:px-3.5 group-data-[size=lg]/input-group:py-3 group-data-[size=lg]/input-group:md:text-base";
---

<Textarea
  data-slot="input-group-control"
  class={cn("cn-input-group-textarea", textareaClasses, className)}
  {...rest}
/>
