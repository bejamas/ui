---
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from "@bejamas/ui/components/dialog";
import { Button } from "@bejamas/ui/components/button";
import { Switch } from "@bejamas/ui/components/switch";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "@bejamas/ui/components/tabs";
import type { DesignSystemConfig } from "@bejamas/create-config/server";
import {
  buildCreateProjectCommand,
  CREATE_PROJECT_PACKAGE_MANAGERS,
  getCreateProjectDialogState,
} from "@/utils/create-project-dialog";

interface Props {
  config: DesignSystemConfig;
  preset: string;
  themeRef?: string | null;
}

const { config, preset, themeRef = null } = Astro.props as Props;
const templateState = getCreateProjectDialogState(config.template);
const initialCommands = Object.fromEntries(
  CREATE_PROJECT_PACKAGE_MANAGERS.map((packageManager) => [
    packageManager,
    buildCreateProjectCommand({
      packageManager,
      template: config.template,
      preset,
      themeRef,
    }),
  ]),
);
---

<Dialog id="create-project-dialog" data-create-project-dialog>
  <DialogTrigger asChild class="w-full">
    <Button
      type="button"
      class="rounded-[14px] w-full"
      data-create-open-project-dialog
    >
      <span>Create</span>
    </Button>
  </DialogTrigger>

  <DialogContent
    class="w-[min(94vw,32rem)] rounded-[22px] border border-border/70 bg-background p-5 shadow-2xl max-w-lg!"
  >
    <DialogHeader>
      <DialogTitle>Create Project</DialogTitle>
      <DialogDescription>
        Pick an Astro starter and configure the generated init command.
      </DialogDescription>
    </DialogHeader>

    <div>
      <div
        class="space-y-3 rounded-[18px] border border-border bg-muted/20 px-4 py-3"
      >
        <label class="flex items-center justify-between gap-4">
          <span class="min-w-0">
            <span class="block text-sm font-medium text-foreground">
              Create a monorepo
            </span>
            <span
              class="block text-xs text-muted-foreground max-w-80 text-pretty"
            >
              Scaffold the Astro monorepo starter instead of the single-app
              starter.
            </span>
          </span>
          <Switch
            id="create-project-monorepo"
            checked={templateState.monorepo}
            data-create-project-monorepo
          />
        </label>
      </div>
    </div>

    <DialogFooter class="flex flex-col gap-4">
      <input type="hidden" value="bun" data-create-project-package-manager />

      <Tabs
        id="create-project-package-tabs"
        data-create-project-package-tabs
        defaultValue="bun"
        class="min-w-0 overflow-hidden rounded-[18px] border border-border bg-muted/20"
      >
        <div class="px-2 pt-2">
          <TabsList class="w-fit gap-1 rounded-[12px] bg-background/80 p-1">
            {
              CREATE_PROJECT_PACKAGE_MANAGERS.map((packageManager) => (
                <TabsTrigger
                  value={packageManager}
                  class="px-2.5 font-mono text-xs data-[state=active]:shadow-none"
                >
                  {packageManager}
                </TabsTrigger>
              ))
            }
          </TabsList>
        </div>

        {
          CREATE_PROJECT_PACKAGE_MANAGERS.map((packageManager) => (
            <TabsContent value={packageManager} class="mt-0">
              <div class="min-w-0 border-t border-border/70 bg-background/80 px-4 py-4">
                <div class="max-w-full overflow-x-auto">
                  <code
                    class="block w-max min-w-full overflow-scroll [scrollbar-width:none] max-w-sm text-sm whitespace-nowrap text-foreground"
                    data-create-project-command={packageManager}
                  >
                    {initialCommands[packageManager]}
                  </code>
                </div>
              </div>
            </TabsContent>
          ))
        }
      </Tabs>

      <Button type="button" class="w-full" data-create-project-copy-command>
        <span data-create-project-copy-command-label>Copy Command</span>
      </Button>
    </DialogFooter>
  </DialogContent>
</Dialog>
