---
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "@bejamas/registry/ui/accordion";
import {
  Avatar,
  AvatarBadge,
  AvatarFallback,
  AvatarImage,
} from "@bejamas/registry/ui/avatar";
import { Badge } from "@bejamas/registry/ui/badge";
import { Button } from "@bejamas/registry/ui/button";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@bejamas/registry/ui/card";
import { Checkbox } from "@bejamas/registry/ui/checkbox";
import {
  Field,
  FieldContent,
  FieldDescription,
  FieldGroup,
  FieldLabel,
} from "@bejamas/registry/ui/field";
import { Input } from "@bejamas/registry/ui/input";
import {
  Item,
  ItemActions,
  ItemContent,
  ItemDescription,
  ItemGroup,
  ItemMedia,
  ItemSeparator,
  ItemTitle,
} from "@bejamas/registry/ui/item";
import {
  Popover,
  PopoverContent,
  PopoverHeader,
  PopoverTitle,
  PopoverDescription,
  PopoverTrigger,
} from "@bejamas/registry/ui/popover";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectGroup,
  SelectValue,
} from "@bejamas/registry/ui/select";
import { Switch } from "@bejamas/registry/ui/switch";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "@bejamas/registry/ui/tabs";
import { Textarea } from "@bejamas/registry/ui/textarea";
import {
  ToggleGroup,
  ToggleGroupItem,
} from "@bejamas/registry/ui/toggle-group";
import {
  Tooltip,
  TooltipContent,
  TooltipTrigger,
} from "@bejamas/registry/ui/tooltip";
import SemanticIcon from "@/components/icons/SemanticIcon.astro";
import type { IconLibraryName } from "@bejamas/create-config/server";
import {
  CREATE_PREVIEW_TRANSLATIONS,
  type CreatePreviewCopy,
} from "@/utils/create-preview-i18n";

interface Props {
  iconLibrary?: IconLibraryName;
  iconLibraryLabel?: string;
  styleLabel?: string;
  fontLabel?: string;
  radiusLabel?: string;
  menuColorLabel?: string;
  menuInverted?: boolean;
  menuTranslucent?: boolean;
  copy?: CreatePreviewCopy;
}

const {
  iconLibrary = "lucide",
  menuColorLabel = "default",
  menuInverted = false,
  menuTranslucent = false,
  copy = CREATE_PREVIEW_TRANSLATIONS.en,
} = Astro.props as Props;
---

<div
  data-create-preview-surface
  class="min-h-screen bg-background text-foreground"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-8 p-6 md:p-8">
    <div class="grid gap-3 md:grid-cols-[1.4fr_0.9fr]">
      <Card>
        <CardHeader>
          <!-- <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="space-y-2">
              <div class="flex flex-wrap items-center gap-2">
                <Badge>bejamas/ui</Badge>
                <Badge variant="outline" data-create-icon-library-label
                  >{iconLibraryLabel}</Badge
                >
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <Badge variant="secondary" data-create-style-label
                  >{styleLabel}</Badge
                >
                <Badge variant="outline" data-create-font-label
                  >{fontLabel}</Badge
                >
                <Badge variant="outline" data-create-template-label
                  >{templateLabel}</Badge
                >
                <Badge variant="outline" data-create-radius-label
                  >{radiusLabel}</Badge
                >
              </div>
            </div>
            <DropdownMenu>
              <DropdownMenuTrigger asChild>
                <Button variant="outline" size="sm"> Workspace </Button>
              </DropdownMenuTrigger>
              <DropdownMenuContent align="end">
                <DropdownMenuItem>
                  Billing
                  <DropdownMenuShortcut>G B</DropdownMenuShortcut>
                </DropdownMenuItem>
                <DropdownMenuItem>
                  Team settings
                  <DropdownMenuShortcut>G T</DropdownMenuShortcut>
                </DropdownMenuItem>
                <DropdownMenuSeparator />
                <DropdownMenuItem>Sign out</DropdownMenuItem>
              </DropdownMenuContent>
            </DropdownMenu>
          </div> -->
          <CardTitle data-create-preview-text="hero.title"
            >{copy["hero.title"]}</CardTitle
          >
          <CardDescription data-create-preview-text="hero.description">
            {copy["hero.description"]}
          </CardDescription>
        </CardHeader>
        <CardContent class="grid gap-4 md:grid-cols-2">
          <FieldGroup class="gap-4">
            <Field>
              <FieldLabel
                for="preview-project-name"
                data-create-preview-text="form.projectName"
              >
                {copy["form.projectName"]}
              </FieldLabel>
              <Input id="preview-project-name" value="bejamas-site" />
            </Field>
            <Field>
              <FieldLabel
                for="preview-feedback"
                data-create-preview-text="form.feedback"
              >
                {copy["form.feedback"]}
              </FieldLabel>
              <Textarea
                id="preview-feedback"
                rows={4}
                placeholder={copy["form.feedbackPlaceholder"]}
                data-create-preview-placeholder="form.feedbackPlaceholder"
              />
            </Field>
          </FieldGroup>
          <FieldGroup class="gap-4">
            <Field>
              <FieldLabel
                for="preview-region"
                data-create-preview-text="form.region"
              >
                {copy["form.region"]}
              </FieldLabel>
              <Select class="w-full" defaultValue="eu">
                <SelectTrigger id="preview-region">
                  <SelectValue
                    placeholder={copy["form.regionPlaceholder"]}
                    data-create-preview-placeholder="form.regionPlaceholder"
                  />
                </SelectTrigger>
                <SelectContent>
                  <SelectGroup>
                    <SelectItem
                      value="eu"
                      data-create-preview-text="form.regionEu"
                    >
                      {copy["form.regionEu"]}
                    </SelectItem>
                    <SelectItem
                      value="us"
                      data-create-preview-text="form.regionUs"
                    >
                      {copy["form.regionUs"]}
                    </SelectItem>
                    <SelectItem
                      value="apac"
                      data-create-preview-text="form.regionApac"
                    >
                      {copy["form.regionApac"]}
                    </SelectItem>
                  </SelectGroup>
                </SelectContent>
              </Select>
              <FieldDescription
                data-create-preview-text="form.regionDescription"
              >
                {copy["form.regionDescription"]}
              </FieldDescription>
            </Field>
            <div class="rounded-xl border border-border p-4">
              <FieldGroup data-slot="checkbox-group">
                <Field orientation="horizontal">
                  <Switch id="preview-email-digests" checked />
                  <FieldContent>
                    <FieldLabel
                      for="preview-email-digests"
                      data-create-preview-text="form.emailDigests"
                    >
                      {copy["form.emailDigests"]}
                    </FieldLabel>
                    <FieldDescription
                      data-create-preview-text="form.emailDigestsDescription"
                    >
                      {copy["form.emailDigestsDescription"]}
                    </FieldDescription>
                  </FieldContent>
                </Field>
                <Field orientation="horizontal">
                  <Checkbox id="preview-release-notes" checked />
                  <FieldContent>
                    <FieldLabel
                      for="preview-release-notes"
                      data-create-preview-text="form.releaseNotes"
                    >
                      {copy["form.releaseNotes"]}
                    </FieldLabel>
                    <FieldDescription
                      data-create-preview-text="form.releaseNotesDescription"
                    >
                      {copy["form.releaseNotesDescription"]}
                    </FieldDescription>
                  </FieldContent>
                </Field>
              </FieldGroup>
            </div>
          </FieldGroup>
        </CardContent>
        <CardFooter
          class="flex flex-wrap items-center justify-between gap-3 mt-auto"
        >
          <div class="flex items-center gap-2">
            <Avatar>
              <AvatarImage src="https://github.com/thomkrupa.png" alt="Thom" />
              <AvatarFallback>TK</AvatarFallback>
              <AvatarBadge />
            </Avatar>
            <div class="text-sm">
              <p class="font-medium" data-create-preview-text="team.name">
                {copy["team.name"]}
              </p>
              <p
                class="text-muted-foreground"
                data-create-preview-text="team.reviewers"
              >
                {copy["team.reviewers"]}
              </p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <Button
              variant="outline"
              data-create-preview-text="actions.previewDocs"
            >
              {copy["actions.previewDocs"]}
            </Button>
            <Button>
              <SemanticIcon
                library={iconLibrary}
                name="sparkles"
                class="size-4"
              />
              <span data-create-preview-text="actions.createProject">
                {copy["actions.createProject"]}
              </span>
            </Button>
          </div>
        </CardFooter>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle data-create-preview-text="quickActions.title">
            {copy["quickActions.title"]}
          </CardTitle>
          <CardDescription data-create-preview-text="quickActions.description">
            {copy["quickActions.description"]}
          </CardDescription>
        </CardHeader>
        <CardContent class="space-y-4">
          <ToggleGroup variant="outline" defaultValue="bold">
            <ToggleGroupItem value="bold" aria-label="Bold">
              <SemanticIcon library={iconLibrary} name="bold" class="size-4" />
            </ToggleGroupItem>
            <ToggleGroupItem value="italic" aria-label="Italic">
              <SemanticIcon
                library={iconLibrary}
                name="italic"
                class="size-4"
              />
            </ToggleGroupItem>
            <ToggleGroupItem value="underline" aria-label="Underline">
              <SemanticIcon
                library={iconLibrary}
                name="underline"
                class="size-4"
              />
            </ToggleGroupItem>
          </ToggleGroup>

          <Tabs defaultValue="overview">
            <TabsList variant="indicator">
              <TabsTrigger
                value="overview"
                data-create-preview-text="quickActions.tabOverview"
              >
                {copy["quickActions.tabOverview"]}
              </TabsTrigger>
              <TabsTrigger
                value="activity"
                data-create-preview-text="quickActions.tabActivity"
              >
                {copy["quickActions.tabActivity"]}
              </TabsTrigger>
            </TabsList>
            <TabsContent value="overview" class="pt-3">
              <Item variant="outline">
                <ItemMedia>
                  <SemanticIcon
                    library={iconLibrary}
                    name="bell"
                    class="size-4 text-muted-foreground"
                  />
                </ItemMedia>
                <ItemContent>
                  <ItemTitle
                    data-create-preview-text="quickActions.notificationsEnabled"
                  >
                    {copy["quickActions.notificationsEnabled"]}
                  </ItemTitle>
                  <ItemDescription
                    data-create-preview-text="quickActions.notificationsDescription"
                  >
                    {copy["quickActions.notificationsDescription"]}
                  </ItemDescription>
                </ItemContent>
                <ItemActions>
                  <Button variant="ghost" size="icon" aria-label="More">
                    <SemanticIcon
                      library={iconLibrary}
                      name="ellipsis"
                      class="size-4"
                    />
                  </Button>
                </ItemActions>
              </Item>
            </TabsContent>
            <TabsContent value="activity" class="pt-3">
              <ItemGroup class="rounded-xl border border-border">
                <Item>
                  <ItemMedia>
                    <SemanticIcon
                      library={iconLibrary}
                      name="calendar"
                      class="size-4 text-muted-foreground"
                    />
                  </ItemMedia>
                  <ItemContent>
                    <ItemTitle
                      data-create-preview-text="quickActions.weeklyReview"
                    >
                      {copy["quickActions.weeklyReview"]}
                    </ItemTitle>
                    <ItemDescription
                      data-create-preview-text="quickActions.weeklyReviewTime"
                    >
                      {copy["quickActions.weeklyReviewTime"]}
                    </ItemDescription>
                  </ItemContent>
                </Item>
                <ItemSeparator />
                <Item>
                  <ItemMedia>
                    <SemanticIcon
                      library={iconLibrary}
                      name="globe"
                      class="size-4 text-muted-foreground"
                    />
                  </ItemMedia>
                  <ItemContent>
                    <ItemTitle
                      data-create-preview-text="quickActions.registrySynced"
                    >
                      {copy["quickActions.registrySynced"]}
                    </ItemTitle>
                    <ItemDescription
                      data-create-preview-text="quickActions.registrySyncedDescription"
                    >
                      {copy["quickActions.registrySyncedDescription"]}
                    </ItemDescription>
                  </ItemContent>
                </Item>
              </ItemGroup>
            </TabsContent>
          </Tabs>

          <div class="grid gap-3 rounded-xl border border-border p-4">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p
                  class="text-sm font-medium"
                  data-create-preview-text="quickActions.menuSurface"
                >
                  {copy["quickActions.menuSurface"]}
                </p>
                <p
                  class="text-sm text-muted-foreground"
                  data-create-preview-text="quickActions.menuSurfaceDescription"
                >
                  {copy["quickActions.menuSurfaceDescription"]}
                </p>
              </div>
              <Badge variant="outline" data-create-menu-color-label
                >{menuColorLabel}</Badge
              >
            </div>
            <div
              data-create-menu-preview
              class:list={[
                "cn-menu-target rounded-xl border border-border bg-popover p-1 text-popover-foreground shadow-md",
                menuInverted && "dark",
                menuTranslucent && "cn-menu-translucent",
              ]}
            >
              <div
                class="rounded-[calc(var(--radius)-2px)] bg-accent px-3 py-2 text-sm text-accent-foreground"
                data-create-preview-text="quickActions.activeMenuItem"
              >
                {copy["quickActions.activeMenuItem"]}
              </div>
              <div
                class="px-3 py-2 text-sm text-muted-foreground"
                data-create-preview-text="quickActions.secondaryAction"
              >
                {copy["quickActions.secondaryAction"]}
              </div>
              <div
                class="mt-1 border-t border-border px-3 py-2 text-sm"
                data-create-preview-text="quickActions.billingPortal"
              >
                {copy["quickActions.billingPortal"]}
              </div>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
      <Card>
        <CardHeader>
          <CardTitle data-create-preview-text="structured.title">
            {copy["structured.title"]}
          </CardTitle>
          <CardDescription data-create-preview-text="structured.description">
            {copy["structured.description"]}
          </CardDescription>
        </CardHeader>
        <CardContent class="grid gap-4">
          <Accordion collapsible class="w-full">
            <AccordionItem value="item-1">
              <AccordionTrigger>
                <span
                  data-create-preview-text="structured.accordionInstallQuestion"
                >
                  {copy["structured.accordionInstallQuestion"]}
                </span>
              </AccordionTrigger>
              <AccordionContent>
                <span
                  data-create-preview-text="structured.accordionInstallAnswer"
                >
                  {copy["structured.accordionInstallAnswer"]}
                </span>
              </AccordionContent>
            </AccordionItem>
            <AccordionItem value="item-2">
              <AccordionTrigger>
                <span
                  data-create-preview-text="structured.accordionComponentsQuestion"
                >
                  {copy["structured.accordionComponentsQuestion"]}
                </span>
              </AccordionTrigger>
              <AccordionContent>
                <span
                  data-create-preview-text="structured.accordionComponentsAnswer"
                >
                  {copy["structured.accordionComponentsAnswer"]}
                </span>
              </AccordionContent>
            </AccordionItem>
          </Accordion>

          <div class="flex flex-wrap gap-3">
            <Popover>
              <PopoverTrigger
                variant="outline"
                data-create-preview-text="structured.billingSummary"
              >
                {copy["structured.billingSummary"]}
              </PopoverTrigger>
              <PopoverContent align="start">
                <PopoverHeader>
                  <PopoverTitle
                    data-create-preview-text="structured.currentPlan"
                  >
                    {copy["structured.currentPlan"]}
                  </PopoverTitle>
                  <PopoverDescription
                    data-create-preview-text="structured.currentPlanDescription"
                  >
                    {copy["structured.currentPlanDescription"]}
                  </PopoverDescription>
                </PopoverHeader>
              </PopoverContent>
            </Popover>

            <Tooltip>
              <TooltipTrigger asChild>
                <Button variant="outline">
                  <SemanticIcon
                    library={iconLibrary}
                    name="credit-card"
                    class="size-4"
                  />
                  <span data-create-preview-text="structured.cardRequired">
                    {copy["structured.cardRequired"]}
                  </span>
                </Button>
              </TooltipTrigger>
              <TooltipContent
                data-create-preview-text="structured.cardRequiredTooltip"
              >
                {copy["structured.cardRequiredTooltip"]}
              </TooltipContent>
            </Tooltip>
          </div>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle data-create-preview-text="people.title">
            {copy["people.title"]}
          </CardTitle>
          <CardDescription data-create-preview-text="people.description">
            {copy["people.description"]}
          </CardDescription>
        </CardHeader>
        <CardContent class="space-y-4">
          <div class="flex items-center gap-3">
            <Avatar size="lg">
              <AvatarImage src="https://github.com/withastro.png" alt="Astro" />
              <AvatarFallback>AS</AvatarFallback>
            </Avatar>
            <div>
              <p class="font-medium" data-create-preview-text="people.teamName">
                {copy["people.teamName"]}
              </p>
              <p
                class="text-sm text-muted-foreground"
                data-create-preview-text="people.teamRole"
              >
                {copy["people.teamRole"]}
              </p>
            </div>
            <Badge
              variant="secondary"
              data-create-preview-text="people.coreBadge"
            >
              {copy["people.coreBadge"]}
            </Badge>
          </div>

          <ItemGroup class="rounded-xl border border-border">
            <Item>
              <ItemMedia>
                <Avatar size="sm">
                  <AvatarFallback>RM</AvatarFallback>
                </Avatar>
              </ItemMedia>
              <ItemContent>
                <ItemTitle data-create-preview-text="people.releaseManager">
                  {copy["people.releaseManager"]}
                </ItemTitle>
                <ItemDescription
                  data-create-preview-text="people.releaseManagerDescription"
                >
                  {copy["people.releaseManagerDescription"]}
                </ItemDescription>
              </ItemContent>
            </Item>
            <ItemSeparator />
            <Item>
              <ItemMedia>
                <Avatar size="sm">
                  <AvatarFallback>DX</AvatarFallback>
                </Avatar>
              </ItemMedia>
              <ItemContent>
                <ItemTitle
                  data-create-preview-text="people.developerExperience"
                >
                  {copy["people.developerExperience"]}
                </ItemTitle>
                <ItemDescription
                  data-create-preview-text="people.developerExperienceDescription"
                >
                  {copy["people.developerExperienceDescription"]}
                </ItemDescription>
              </ItemContent>
            </Item>
          </ItemGroup>
        </CardContent>
      </Card>
    </div>
  </div>
</div>

<style is:global>
  [data-create-preview-surface]
    :is(input, textarea)[data-create-preview-placeholder]::placeholder {
    color: var(--muted-foreground);
    opacity: 1;
  }
</style>
