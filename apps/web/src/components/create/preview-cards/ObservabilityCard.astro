---
import { Button } from "@bejamas/registry/ui/button";
import { Image } from "astro:assets";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
  CardMedia,
} from "@bejamas/registry/ui/card";
---

<Card class="w-full overflow-hidden">
  <CardMedia>
    <Image
      src="https://gradient.bejamas.com/api/gradient.png?funkiness=30&contrast=0&w=748&h=500&seed=bejamas"
      alt="Gradient Cover"
      class="w-full h-full object-cover"
      width="374"
      height="250"
      loading="lazy"
    />
  </CardMedia>
  <CardHeader>
    <CardTitle>Observability Plus is replacing Monitoring</CardTitle>
    <CardDescription>
      Query traces, logs, and incidents from the same workflow instead of
      hopping between dashboards.
    </CardDescription>
  </CardHeader>
  <CardContent class="text-sm text-muted-foreground">
    Includes trace drilldowns, issue grouping, and release-aware deploy markers.
  </CardContent>
  <CardFooter class="gap-2">
    <Button variant="outline" class="flex-1">Read update</Button>
    <Button class="flex-1">Enable beta</Button>
  </CardFooter>
</Card>
