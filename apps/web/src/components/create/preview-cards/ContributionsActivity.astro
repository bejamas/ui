---
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@bejamas/registry/ui/card";

const activity = [
  0, 1, 0, 2, 1, 0, 3,
  1, 2, 1, 3, 2, 0, 2,
  0, 1, 2, 2, 1, 3, 1,
  2, 0, 1, 3, 2, 1, 2,
] as const;
---

<Card class="w-full">
  <CardHeader>
    <CardTitle>Contributions &amp; Activity</CardTitle>
    <CardDescription>Recent deploys, releases, and docs updates.</CardDescription>
  </CardHeader>
  <CardContent class="space-y-4">
    <div class="grid grid-cols-7 gap-2">
      {
        activity.map((value) => (
          <div
            class:list={[
              "aspect-square rounded-md border border-border",
              value === 0 && "bg-muted",
              value === 1 && "bg-primary/20",
              value === 2 && "bg-primary/45",
              value === 3 && "bg-primary/70",
            ]}
          />
        ))
      }
    </div>
    <div class="grid grid-cols-3 gap-3 text-sm">
      <div>
        <p class="text-muted-foreground">Deploys</p>
        <p class="font-medium tabular-nums">18</p>
      </div>
      <div>
        <p class="text-muted-foreground">Merged</p>
        <p class="font-medium tabular-nums">42</p>
      </div>
      <div>
        <p class="text-muted-foreground">Docs</p>
        <p class="font-medium tabular-nums">11</p>
      </div>
    </div>
  </CardContent>
</Card>
