---
import { Button } from "@bejamas/registry/ui/button";
import {
  DropdownMenu,
  DropdownMenuTrigger,
  DropdownMenuContent,
  DropdownMenuGroup,
  DropdownMenuItem,
  DropdownMenuSeparator,
} from "@bejamas/registry/ui/dropdown-menu";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardTitle,
} from "@bejamas/registry/ui/card";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "@bejamas/registry/ui/tabs";
import SemanticIcon from "@/components/icons/SemanticIcon.astro";
import type { IconLibraryName } from "@bejamas/create-config/server";

interface Props {
  iconLibrary: IconLibraryName;
  menuColorLabel: string;
  menuInverted?: boolean;
  menuTranslucent?: boolean;
}

const { iconLibrary } = Astro.props as Props;
---

<Card class="w-full">
  <CardContent class="space-y-4">
    <Tabs defaultValue="codespaces">
      <TabsList variant="indicator" class="w-full">
        <TabsTrigger value="codespaces">Codespaces</TabsTrigger>
        <TabsTrigger value="local">Local</TabsTrigger>
      </TabsList>
      <TabsContent value="codespaces" class="space-y-4 pt-4">
        <div class="flex items-start justify-between gap-3">
          <div>
            <CardTitle class="text-base">Codespaces</CardTitle>
            <CardDescription>Your workspaces in the cloud</CardDescription>
          </div>
          <div class="flex items-center gap-1">
            <Button variant="ghost" size="icon-sm" aria-label="Create">
              <SemanticIcon library={iconLibrary} name="plus" class="size-4" />
            </Button>
            <DropdownMenu>
              <DropdownMenuTrigger asChild>
                <Button variant="ghost" size="icon-sm" aria-label="More">
                  <SemanticIcon
                    library={iconLibrary}
                    name="ellipsis"
                    class="size-4"
                  />
                </Button>
              </DropdownMenuTrigger>
              <DropdownMenuContent align="end" class="w-56">
                <DropdownMenuGroup>
                  <DropdownMenuItem>New with options...</DropdownMenuItem>
                  <DropdownMenuItem>Configure dev container</DropdownMenuItem>
                  <DropdownMenuItem>Set up prebuilds</DropdownMenuItem>
                </DropdownMenuGroup>
                <DropdownMenuSeparator />
                <DropdownMenuGroup>
                  <DropdownMenuItem>Manage codespaces</DropdownMenuItem>
                  <DropdownMenuItem>Share deep link</DropdownMenuItem>
                  <DropdownMenuItem>What are codespaces?</DropdownMenuItem>
                </DropdownMenuGroup>
              </DropdownMenuContent>
            </DropdownMenu>
          </div>
        </div>

        <div
          class="rounded-xl border border-dashed border-border px-6 py-10 text-center"
        >
          <div
            class="mx-auto mb-4 flex size-12 items-center justify-center rounded-full border border-border"
          >
            <SemanticIcon
              library={iconLibrary}
              name="copy"
              class="size-5 text-muted-foreground"
            />
          </div>
          <p class="font-medium">No codespaces</p>
          <p class="mt-2 text-sm text-muted-foreground">
            You don&apos;t have any codespaces with this repository checked out.
          </p>
          <Button class="mt-4" size="sm">Create Codespace</Button>
          <p
            class="mt-3 text-xs text-muted-foreground underline underline-offset-4"
          >
            Learn more about codespaces
          </p>
        </div>
      </TabsContent>
      <TabsContent value="local" class="pt-4 text-sm text-muted-foreground">
        Local environments stay available for offline workflows and CI
        debugging.
      </TabsContent>
    </Tabs>
  </CardContent>
  <CardFooter
    class="flex items-center justify-between gap-3 border-t border-border pt-4"
  >
    <p class="text-sm text-muted-foreground">
      Codespace a day keeps the doctor away.
    </p>
    <!-- <Badge
      variant="outline"
      data-create-menu-color-label
      data-create-menu-preview
      class:list={[
        menuInverted && "dark",
        menuTranslucent && "cn-menu-translucent",
      ]}
    >
      {menuColorLabel}
    </Badge> -->
  </CardFooter>
</Card>
