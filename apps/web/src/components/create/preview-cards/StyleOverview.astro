---
import { Badge } from "@bejamas/registry/ui/badge";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@bejamas/registry/ui/card";

interface Props {
  styleLabel?: string;
  fontLabel?: string;
  radiusLabel?: string;
}

const { styleLabel, fontLabel, radiusLabel = "default" } = Astro.props as Props;

const overviewTokens = [
  "--background",
  "--foreground",
  "--card",
  "--popover",
  "--primary",
  "--secondary",
  "--muted",
  "--accent",
  "--destructive",
  "--border",
  "--input",
  "--ring",
] as const;

const summary =
  [styleLabel, fontLabel].filter(Boolean).join(" - ") || "Juno - Inter";
---

<Card class="w-full">
  <CardHeader>
    <CardTitle class="text-2xl font-medium" data-create-style-font-summary>
      {summary}
    </CardTitle>
    <CardDescription>
      Preview the core theme tokens without relying on chart-only variables.
    </CardDescription>
  </CardHeader>
  <CardContent>
    <div class="grid grid-cols-3 gap-3 sm:grid-cols-4 xl:grid-cols-6">
      {
        overviewTokens.map((token) => (
          <div class="flex flex-col items-center gap-2">
            <div
              class="relative aspect-square w-full rounded-xl bg-(--color) after:absolute after:inset-0 after:rounded-xl after:border after:border-border after:mix-blend-darken dark:after:mix-blend-lighten"
              style={{ "--color": `var(${token})` }}
            />
            <span class="max-w-full truncate font-mono text-[0.625rem] text-muted-foreground">
              {token}
            </span>
          </div>
        ))
      }
    </div>
  </CardContent>
</Card>
