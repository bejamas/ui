---
import { Badge } from "@bejamas/registry/ui/badge";
import { Button } from "@bejamas/registry/ui/button";
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@bejamas/registry/ui/card";
import SemanticIcon from "@/components/icons/SemanticIcon.astro";
import type { IconLibraryName } from "@bejamas/create-config/server";

interface Props {
  iconLibrary: IconLibraryName;
}

const { iconLibrary } = Astro.props as Props;

const features = [
  "Autofix failing checks and broken links",
  "Summarize risky deploys before release",
  "Suggest rollout-safe recovery steps",
] as const;
---

<Card class="w-full">
  <CardHeader>
    <div class="flex items-center gap-2">
      <Badge>Beta</Badge>
      <Badge variant="outline">Agent</Badge>
    </div>
    <CardTitle>Ship faster &amp; safer with Vercel Agent</CardTitle>
    <CardDescription>
      Review pull requests, release notes, and deploy health from one assistant-oriented flow.
    </CardDescription>
  </CardHeader>
  <CardContent class="space-y-3">
    {
      features.map((feature) => (
        <div class="flex items-start gap-3 rounded-lg border border-border px-3 py-2">
          <SemanticIcon library={iconLibrary} name="check" class="mt-0.5 size-4 text-primary" />
          <span class="text-sm">{feature}</span>
        </div>
      ))
    }
  </CardContent>
  <CardFooter class="gap-2">
    <Button variant="outline" class="flex-1">Learn more</Button>
    <Button class="flex-1">
      <SemanticIcon library={iconLibrary} name="sparkles" class="size-4" />
      Activate agent
    </Button>
  </CardFooter>
</Card>
