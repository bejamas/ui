---
import ArrowLeftIcon from "@lucide/astro/icons/arrow-left";
import { resolveDesignSystemTheme } from "@/utils/themes/design-system-adapter";
import {
  CREATE_THEME_TOKEN_SECTIONS,
  formatThemeTokenLabel,
  type ThemeOverrides,
} from "@/utils/themes/create-theme";
import ColorInput from "@/components/theme-editor/ColorInput.astro";
import type { DesignSystemConfig } from "@bejamas/create-config/server";
import { Button } from "@bejamas/registry/ui/button";

interface Props {
  config: DesignSystemConfig;
  themeRef?: string | null;
  themeOverrides?: ThemeOverrides | null;
}

const { config, themeOverrides = null } = Astro.props as Props;
const resolvedTheme = resolveDesignSystemTheme(config, themeOverrides).styles;
---

<section
  hidden
  class="create-panel-transition bg-[#0040a1] ml-5 space-y-3.5 xl:min-h-0 p-2.5 xl:flex xl:flex-1 xl:flex-col xl:overflow-hidden"
  data-create-palette-panel
  data-panel-state="inactive"
  data-create-sidebar-target="palettePanel"
>
  <div class="flex items-center justify-between gap-2">
    <div class="min-w-0">
      <span class="block text-[8px] font-semibold uppercase tracking-[0.12em] text-white/38">
        Theme
      </span>
      <span
        class="block truncate text-sm font-medium tracking-[-0.01em] text-white/90"
        data-palette-theme-label
        data-create-sidebar-target="paletteThemeLabel"
      >
      </span>
    </div>
    <span
      class="inline-flex size-5 shrink-0 rounded-full border border-white/18 shadow-[inset_0_1px_0_rgba(255,255,255,0.14)]"
      data-palette-theme-swatch
      data-create-sidebar-target="paletteThemeSwatch"
    >
    </span>
  </div>

  <Button
    variant="outline"
    size="sm"
    type="button"
    data-create-palette-back
    data-create-sidebar-target="paletteBackButton"
    data-action="click->create-sidebar#cancelPalette"
  >
    <ArrowLeftIcon class="size-3 text-white/70" />
    Go back
  </Button>

  <div class="overflow-auto gap-4 flex flex-col xl:flex-1">
    {
      (["light", "dark"] as const).map((mode, index) => (
        <div
          class:list={[index > 0 && "hidden"]}
          data-create-theme-mode-panel
          data-mode={mode}
          data-create-sidebar-target="themeModePanel"
        >
          <div class="grid grid-cols-2 gap-x-2 gap-y-4">
            {CREATE_THEME_TOKEN_SECTIONS.flatMap((section) =>
              section.tokens.map((token) => (
                <ColorInput
                  token={token}
                  label={formatThemeTokenLabel(token)}
                  value={resolvedTheme[mode][token] ?? ""}
                  variant="palette"
                  class="p-2"
                  data-create-theme-input
                  data-create-theme-mode={mode}
                  data-create-sidebar-target="colorInput"
                  data-action="color-change->create-sidebar#handleColorChange"
                  data-create-sidebar-mode-param={mode}
                  data-create-sidebar-token-param={token}
                />
              ))
            )}
          </div>
        </div>
      ))
    }
  </div>
</section>
