---
import { Tabs, TabsList, TabsTrigger } from "@bejamas/registry/ui/tabs";

import { SunIcon, MoonIcon, LaptopIcon } from "@lucide/astro";
import ThemeEditorGlobal from "./theme-editor/ThemeEditorGlobal.astro";
---

<div class="flex items-center">
  <starlight-theme-select>
    <Tabs defaultValue="auto" class="theme-tabs">
      <TabsList>
        <TabsTrigger
          value="light"
          class="theme-tab p-0 aspect-square"
          title="Light theme"
        >
          <SunIcon class="size-4 block" />
        </TabsTrigger>
        <TabsTrigger
          value="dark"
          class="theme-tab p-0 aspect-square"
          title="Dark theme"
        >
          <MoonIcon class="size-4" />
        </TabsTrigger>
        <TabsTrigger
          value="auto"
          class="theme-tab p-0 aspect-square"
          title="Auto (system)"
        >
          <LaptopIcon class="size-4" />
        </TabsTrigger>
      </TabsList>
    </Tabs>
  </starlight-theme-select>
</div>

<!-- Legacy theme editor stays mounted but hidden during the /create transition. -->
<div hidden aria-hidden="true">
  <ThemeEditorGlobal />
</div>

<script is:inline>
  (() => {
    const script = document.currentScript;
    const root = script?.previousElementSibling?.previousElementSibling;

    if (!(root instanceof HTMLElement)) {
      return;
    }

    const tabsRoot = root.querySelector('[data-slot="tabs"]');
    if (!(tabsRoot instanceof HTMLElement)) {
      return;
    }

    const parseThemeChoice = (value) =>
      value === "light" || value === "dark" || value === "auto"
        ? value
        : "auto";

    let themeChoice = parseThemeChoice(
      document.documentElement.dataset.themeChoice,
    );

    if (themeChoice === "auto") {
      try {
        themeChoice = parseThemeChoice(localStorage.getItem("starlight-theme"));
      } catch {}
    }

    tabsRoot.dataset.defaultValue = themeChoice;
    tabsRoot.dataset.value = themeChoice;
    tabsRoot.setAttribute("data-theme-tabs-preloaded", "");
  })();
</script>

<script is:inline>
  if (typeof StarlightThemeProvider !== "undefined") {
    StarlightThemeProvider.updatePickers();
  }
</script>

<script>
  import {
    loadStoredThemeChoice,
    parseStoredThemeChoice,
    setGlobalThemeChoice,
    type ThemeChoice,
  } from "@/utils/themes/iframe-theme-sync";

  const loadTheme = (): ThemeChoice => loadStoredThemeChoice(localStorage);

  function onThemeChange(theme: ThemeChoice): void {
    setGlobalThemeChoice(theme, {
      syncPickers: (themeChoice) =>
        window.StarlightThemeProvider?.updatePickers?.(themeChoice),
      dispatchChange: (effectiveTheme, themeChoice) => {
        window.dispatchEvent(
          new CustomEvent("theme-toggle-changed", {
            detail: { theme: effectiveTheme, themeChoice },
          }),
        );
      },
    });
  }

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (loadTheme() === "auto") onThemeChange("auto");
  });

  class StarlightThemeSelect extends HTMLElement {
    private tabsEl: HTMLDivElement | null = null;

    private onTabsChange = (event: Event) => {
      const value = (event as CustomEvent<{ value?: unknown }>).detail?.value;
      if (typeof value !== "string") return;

      const nextTheme = parseStoredThemeChoice(value);
      const currentTheme = parseStoredThemeChoice(
        document.documentElement.dataset.themeChoice,
      );
      if (nextTheme === currentTheme) return;

      onThemeChange(nextTheme);
    };

    connectedCallback() {
      this.tabsEl = this.querySelector<HTMLDivElement>('[data-slot="tabs"]');
      const currentTheme = loadTheme();
      onThemeChange(currentTheme);

      if (this.tabsEl?.hasAttribute("data-theme-tabs-preloaded")) {
        requestAnimationFrame(() => {
          this.tabsEl?.removeAttribute("data-theme-tabs-preloaded");
        });
      }

      this.tabsEl?.addEventListener("tabs:change", this.onTabsChange);
    }

    disconnectedCallback() {
      this.tabsEl?.removeEventListener("tabs:change", this.onTabsChange);
      this.tabsEl = null;
    }
  }

  if (!customElements.get("starlight-theme-select")) {
    customElements.define("starlight-theme-select", StarlightThemeSelect);
  }
</script>

<style>
  .theme-tabs {
    gap: 0;
  }

  .theme-tab[data-state="active"] {
    color: var(--foreground);
  }

  .theme-tab[data-state="inactive"] {
    color: var(--muted-foreground);
  }

  .theme-tabs[data-theme-tabs-preloaded] [data-slot="tabs-indicator"],
  .theme-tabs[data-theme-tabs-preloaded] [data-slot="tabs-trigger"] {
    transition: none;
  }
</style>
