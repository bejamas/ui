---
import {
  Avatar,
  AvatarFallback,
  AvatarImage,
} from "@bejamas/ui/components/avatar";

import type { BlogAuthor } from "@/utils/blog";
import { getAuthorInitials } from "@/utils/blog";

interface Props {
  author: BlogAuthor;
  showRole?: boolean;
  linkAuthor?: boolean;
  size?: "sm" | "default";
}

const {
  author,
  showRole = false,
  linkAuthor = true,
  size = "default",
} = Astro.props as Props;

const initials = getAuthorInitials(author.name);
const wrapperClass = [
  "inline-flex items-center",
  size === "sm" ? "gap-2" : "gap-3",
];
const textClass = size === "sm" ? "text-sm" : "text-sm";
---

{
  linkAuthor && author.href ? (
    <a href={author.href} class:list={wrapperClass}>
      <Avatar size={size === "sm" ? "sm" : "default"} class="shrink-0">
        {author.avatar && (
          <AvatarImage src={author.avatar} alt={author.name} loading="lazy" />
        )}
        <AvatarFallback>{initials}</AvatarFallback>
      </Avatar>
      <span class="min-w-0">
        <span
          class:list={["block truncate font-medium text-foreground", textClass]}
        >
          {author.name}
        </span>
        {showRole && author.role && (
          <span class="block truncate text-xs text-muted-foreground">
            {author.role}
          </span>
        )}
      </span>
    </a>
  ) : (
    <div class:list={wrapperClass}>
      <Avatar size={size === "sm" ? "sm" : "default"} class="shrink-0">
        {author.avatar && (
          <AvatarImage src={author.avatar} alt={author.name} loading="lazy" />
        )}
        <AvatarFallback>{initials}</AvatarFallback>
      </Avatar>
      <span class="min-w-0">
        <span
          class:list={["block truncate font-medium text-foreground", textClass]}
        >
          {author.name}
        </span>
        {showRole && author.role && (
          <span class="block truncate text-xs text-muted-foreground">
            {author.role}
          </span>
        )}
      </span>
    </div>
  )
}
